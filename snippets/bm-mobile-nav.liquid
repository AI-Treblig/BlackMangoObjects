{%- comment -%}
  Black Mango mobile navigation — fully self-contained with inline onclick.
  Inline handlers cannot be blocked by other JS, jQuery interference, or load-order issues.
{%- endcomment -%}

{%- assign menu_handle = settings.menu_link_mobile -%}
{%- assign menu = linklists[menu_handle] -%}
{%- if menu == blank or menu.links.size == 0 -%}
  {%- assign menu = linklists.main-menu -%}
{%- endif -%}

{%- comment -%} Find the logo from the active header section settings if available {%- endcomment -%}
{%- assign mobile_logo = section.settings.logo -%}

<div id="bm-mnav-bar" class="bm-mnav-bar">
  <div class="bm-mnav-bar__inner">
    <button type="button"
            id="bm-mnav-open"
            class="bm-mnav-trigger"
            aria-label="Open menu"
            onclick="document.body.classList.add('bm-mnav-open');return false;">
      <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>

    <a class="bm-mnav-logo" href="/" aria-label="{{ shop.name }}">
      {%- if mobile_logo -%}
        <img src="{{ mobile_logo | image_url: width: 240 }}"
             alt="{{ mobile_logo.alt | default: shop.name }}"
             width="120" height="auto">
      {%- else -%}
        <span class="bm-mnav-logo__text">{{ shop.name }}</span>
      {%- endif -%}
    </a>

    <a href="/cart" class="bm-mnav-cart" aria-label="Cart">
      <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path>
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <path d="M16 10a4 4 0 0 1-8 0"></path>
      </svg>
      <span class="bm-mnav-cart__count">{{ cart.item_count }}</span>
    </a>
  </div>
</div>

<div id="bm-mnav-overlay"
     class="bm-mnav-overlay"
     onclick="document.body.classList.remove('bm-mnav-open')"></div>

<aside id="bm-mnav-drawer" class="bm-mnav-drawer" aria-hidden="true">
  <div class="bm-mnav-drawer__head">
    <span class="bm-mnav-drawer__title">Menu</span>
    <button type="button"
            class="bm-mnav-close"
            aria-label="Close menu"
            onclick="document.body.classList.remove('bm-mnav-open');return false;">
      <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
  </div>

  <nav class="bm-mnav-drawer__body">
    <ul class="bm-mnav-list">
      {%- for link in menu.links -%}
        <li class="bm-mnav-item{% if link.links.size > 0 %} bm-mnav-item--has-children{% endif %}">
          <div class="bm-mnav-row">
            <a class="bm-mnav-link" href="{{ link.url }}">{{ link.title }}</a>
            {%- if link.links.size > 0 -%}
              <button type="button"
                      class="bm-mnav-expand"
                      aria-label="Expand {{ link.title | escape }}"
                      onclick="this.closest('.bm-mnav-item').classList.toggle('is-open');return false;">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
              </button>
            {%- endif -%}
          </div>
          {%- if link.links.size > 0 -%}
            <ul class="bm-mnav-sublist">
              {%- for child in link.links -%}
                <li class="bm-mnav-item{% if child.links.size > 0 %} bm-mnav-item--has-children{% endif %}">
                  <div class="bm-mnav-row">
                    <a class="bm-mnav-link bm-mnav-link--child" href="{{ child.url }}">{{ child.title }}</a>
                    {%- if child.links.size > 0 -%}
                      <button type="button"
                              class="bm-mnav-expand"
                              aria-label="Expand {{ child.title | escape }}"
                              onclick="this.closest('.bm-mnav-item').classList.toggle('is-open');return false;">
                        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                          <polyline points="6 9 12 15 18 9"></polyline>
                        </svg>
                      </button>
                    {%- endif -%}
                  </div>
                  {%- if child.links.size > 0 -%}
                    <ul class="bm-mnav-sublist">
                      {%- for grandchild in child.links -%}
                        <li class="bm-mnav-item">
                          <div class="bm-mnav-row">
                            <a class="bm-mnav-link bm-mnav-link--child" href="{{ grandchild.url }}">{{ grandchild.title }}</a>
                          </div>
                        </li>
                      {%- endfor -%}
                    </ul>
                  {%- endif -%}
                </li>
              {%- endfor -%}
            </ul>
          {%- endif -%}
        </li>
      {%- endfor -%}
    </ul>

    <div class="bm-mnav-footer">
      <a href="/account">Account</a>
      <a href="/search">Search</a>
    </div>
  </nav>
</aside>

<style>
  /* Hide stock theme mobile header on mobile to prevent duplicate UI */
  @media (max-width: 991px) {
    .header-mobile,
    .menu-mobile,
    .header-top-mobile,
    .header-bottom-fixed { display: none !important; }
  }

  /* Mobile bar: visible only below 992px, fixed to viewport top */
  #bm-mnav-bar { display: none; }
  @media (max-width: 991px) {
    #bm-mnav-bar {
      display: block !important;
      position: fixed !important;
      top: 0 !important;
      left: 0 !important;
      right: 0 !important;
      z-index: 9990 !important;
      background: #fff !important;
      border-bottom: 1px solid #eee !important;
      width: 100% !important;
    }
    /* Push page content down so it doesn't hide behind the fixed bar */
    body { padding-top: 60px !important; }
  }
  .bm-mnav-bar__inner {
    display: flex !important;
    align-items: center !important;
    justify-content: space-between !important;
    padding: 10px 16px !important;
    min-height: 56px !important;
  }
  .bm-mnav-trigger,
  .bm-mnav-cart {
    background: transparent;
    border: 0;
    padding: 8px;
    margin: 0;
    cursor: pointer;
    color: #000;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    position: relative;
    text-decoration: none;
    -webkit-tap-highlight-color: transparent;
  }
  .bm-mnav-trigger:active,
  .bm-mnav-cart:active { opacity: .6; }
  .bm-mnav-cart__count {
    position: absolute;
    top: 2px;
    right: 2px;
    background: #000;
    color: #fff;
    border-radius: 999px;
    font-size: 10px;
    line-height: 1;
    padding: 3px 5px;
    min-width: 16px;
    text-align: center;
    font-family: var(--font-family-base), 'Manrope', sans-serif;
  }
  .bm-mnav-logo {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    color: #000;
    font-family: var(--font-family-second), 'Cormorant Garamond', serif;
    font-size: 22px;
  }
  .bm-mnav-logo img {
    max-height: 36px;
    width: auto;
    display: block;
  }
  .bm-mnav-logo__text {
    font-family: var(--font-family-second), 'Cormorant Garamond', serif;
    font-size: 22px;
  }

  /* Overlay */
  #bm-mnav-overlay {
    position: fixed !important;
    inset: 0 !important;
    background: rgba(0,0,0,.5) !important;
    z-index: 9998 !important;
    opacity: 0 !important;
    visibility: hidden !important;
    pointer-events: none !important;
    transition: opacity .25s ease !important;
  }
  body.bm-mnav-open #bm-mnav-overlay {
    opacity: 1 !important;
    visibility: visible !important;
    pointer-events: auto !important;
  }

  /* Drawer */
  #bm-mnav-drawer {
    position: fixed !important;
    top: 0 !important;
    left: 0 !important;
    height: 100vh !important;
    width: min(86vw, 360px) !important;
    background: #fff !important;
    z-index: 9999 !important;
    transform: translateX(-100%) !important;
    transition: transform .3s ease !important;
    display: flex !important;
    flex-direction: column !important;
    box-shadow: 0 0 30px rgba(0,0,0,.1) !important;
    visibility: visible !important;
    opacity: 1 !important;
    margin: 0 !important;
    padding: 0 !important;
  }
  body.bm-mnav-open #bm-mnav-drawer {
    transform: translateX(0) !important;
  }
  body.bm-mnav-open { overflow: hidden !important; }

  .bm-mnav-drawer__head {
    display: flex !important;
    align-items: center !important;
    justify-content: space-between !important;
    padding: 16px 20px !important;
    border-bottom: 1px solid #eee !important;
  }
  .bm-mnav-drawer__title {
    font-family: var(--font-family-second), 'Cormorant Garamond', serif;
    font-size: 20px;
    color: #000;
  }
  .bm-mnav-close {
    background: transparent;
    border: 0;
    padding: 6px;
    cursor: pointer;
    color: #000;
    display: inline-flex;
    -webkit-tap-highlight-color: transparent;
  }
  .bm-mnav-drawer__body {
    flex: 1 1 auto !important;
    overflow-y: auto !important;
    padding: 8px 0 24px !important;
  }
  .bm-mnav-list,
  .bm-mnav-sublist {
    list-style: none !important;
    margin: 0 !important;
    padding: 0 !important;
  }
  .bm-mnav-item { border-bottom: 1px solid #f3f3f3; }
  .bm-mnav-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .bm-mnav-link {
    flex: 1;
    padding: 14px 20px;
    color: #000;
    text-decoration: none;
    font-family: var(--font-family-base), 'Manrope', sans-serif;
    font-size: 15px;
    letter-spacing: .3px;
  }
  .bm-mnav-link--child {
    padding-left: 36px;
    font-size: 14px;
    color: #444;
  }
  .bm-mnav-expand {
    background: transparent;
    border: 0;
    padding: 14px 16px;
    cursor: pointer;
    color: #000;
    display: inline-flex;
    transition: transform .25s ease;
    -webkit-tap-highlight-color: transparent;
  }
  .bm-mnav-item--has-children > .bm-mnav-sublist {
    max-height: 0;
    overflow: hidden;
    transition: max-height .3s ease;
    background: #fafafa;
  }
  .bm-mnav-item.is-open > .bm-mnav-sublist { max-height: 2000px; }
  .bm-mnav-item.is-open > .bm-mnav-row .bm-mnav-expand { transform: rotate(180deg); }

  .bm-mnav-footer {
    display: flex;
    gap: 24px;
    padding: 20px 20px 0;
    border-top: 1px solid #eee;
    margin-top: 12px;
  }
  .bm-mnav-footer a {
    color: #000;
    text-decoration: none;
    font-family: var(--font-family-base), 'Manrope', sans-serif;
    font-size: 14px;
  }
</style>
