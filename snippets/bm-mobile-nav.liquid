{%- comment -%}
  Black Mango mobile navigation — fully self-contained.
  Uses unique class names (bm-mnav-*) to avoid any conflicts with theme JS/CSS.
{%- endcomment -%}

{%- assign menu_handle = settings.menu_link_mobile | default: linklists.main-menu -%}
{%- assign menu = linklists[menu_handle] -%}
{%- if menu == blank or menu.links.size == 0 -%}
  {%- assign menu = linklists.main-menu -%}
{%- endif -%}

<div class="bm-mnav-bar">
  <div class="bm-mnav-bar__inner">
    <button type="button" class="bm-mnav-toggle" aria-label="Open menu" aria-expanded="false" data-bm-mnav-open>
      <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>

    <a class="bm-mnav-logo" href="/" aria-label="{{ shop.name }}">
      {%- if section.settings.logo -%}
        <img src="{{ section.settings.logo | image_url: width: 240 }}"
             alt="{{ section.settings.logo.alt | default: shop.name }}"
             width="120" height="auto">
      {%- else -%}
        <span>{{ shop.name }}</span>
      {%- endif -%}
    </a>

    <div class="bm-mnav-actions">
      {%- if section.settings.show_header_cart -%}
        <a href="/cart" class="bm-mnav-cart" aria-label="Cart">
          <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path>
            <line x1="3" y1="6" x2="21" y2="6"></line>
            <path d="M16 10a4 4 0 0 1-8 0"></path>
          </svg>
          <span class="bm-mnav-cart__count">{{ cart.item_count }}</span>
        </a>
      {%- endif -%}
    </div>
  </div>
</div>

<div class="bm-mnav-overlay" data-bm-mnav-close aria-hidden="true"></div>

<aside class="bm-mnav-drawer" data-bm-mnav-drawer aria-hidden="true">
  <div class="bm-mnav-drawer__head">
    <span class="bm-mnav-drawer__title">Menu</span>
    <button type="button" class="bm-mnav-drawer__close" aria-label="Close menu" data-bm-mnav-close>
      <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
  </div>

  <nav class="bm-mnav-drawer__body">
    <ul class="bm-mnav-list" data-bm-mnav-level="0">
      {%- for link in menu.links -%}
        <li class="bm-mnav-item{% if link.links.size > 0 %} bm-mnav-item--has-children{% endif %}">
          <div class="bm-mnav-row">
            <a class="bm-mnav-link" href="{{ link.url }}">{{ link.title }}</a>
            {%- if link.links.size > 0 -%}
              <button type="button" class="bm-mnav-expand" data-bm-mnav-toggle aria-label="Expand {{ link.title | escape }}" aria-expanded="false">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
              </button>
            {%- endif -%}
          </div>
          {%- if link.links.size > 0 -%}
            <ul class="bm-mnav-sublist">
              {%- for child in link.links -%}
                <li class="bm-mnav-item{% if child.links.size > 0 %} bm-mnav-item--has-children{% endif %}">
                  <div class="bm-mnav-row">
                    <a class="bm-mnav-link bm-mnav-link--child" href="{{ child.url }}">{{ child.title }}</a>
                    {%- if child.links.size > 0 -%}
                      <button type="button" class="bm-mnav-expand" data-bm-mnav-toggle aria-label="Expand {{ child.title | escape }}" aria-expanded="false">
                        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                          <polyline points="6 9 12 15 18 9"></polyline>
                        </svg>
                      </button>
                    {%- endif -%}
                  </div>
                  {%- if child.links.size > 0 -%}
                    <ul class="bm-mnav-sublist">
                      {%- for grandchild in child.links -%}
                        <li class="bm-mnav-item">
                          <div class="bm-mnav-row">
                            <a class="bm-mnav-link bm-mnav-link--child" href="{{ grandchild.url }}">{{ grandchild.title }}</a>
                          </div>
                        </li>
                      {%- endfor -%}
                    </ul>
                  {%- endif -%}
                </li>
              {%- endfor -%}
            </ul>
          {%- endif -%}
        </li>
      {%- endfor -%}
    </ul>

    <div class="bm-mnav-footer">
      <a href="/account">Account</a>
      <a href="/search">Search</a>
    </div>
  </nav>
</aside>

<style>
  /* Hide stock theme mobile header to avoid duplication */
  @media (max-width: 991px) {
    .header-mobile,
    .menu-mobile { display: none !important; }
    .bwp-header > .header { display: none !important; }
  }

  /* Hide our bar above tablet breakpoint */
  .bm-mnav-bar { display: none; }
  @media (max-width: 991px) {
    .bm-mnav-bar {
      display: block;
      position: sticky;
      top: 0;
      z-index: 9990;
      background: #fff;
      border-bottom: 1px solid #eee;
    }
  }
  .bm-mnav-bar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 16px;
    min-height: 56px;
  }
  .bm-mnav-toggle,
  .bm-mnav-cart {
    background: transparent;
    border: 0;
    padding: 8px;
    cursor: pointer;
    color: #000;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    position: relative;
    text-decoration: none;
  }
  .bm-mnav-cart__count {
    position: absolute;
    top: 2px;
    right: 2px;
    background: #000;
    color: #fff;
    border-radius: 999px;
    font-size: 10px;
    line-height: 1;
    padding: 3px 5px;
    min-width: 16px;
    text-align: center;
    font-family: var(--font-family-base), 'Manrope', sans-serif;
  }
  .bm-mnav-logo {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    color: #000;
    font-family: var(--font-family-second), 'Cormorant Garamond', serif;
    font-size: 22px;
  }
  .bm-mnav-logo img {
    max-height: 36px;
    width: auto;
    display: block;
  }

  .bm-mnav-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,.45);
    z-index: 9998;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity .25s ease;
  }
  .bm-mnav-drawer {
    position: fixed;
    top: 0;
    left: 0;
    height: 100vh;
    width: min(86vw, 360px);
    background: #fff;
    z-index: 9999;
    transform: translateX(-100%);
    transition: transform .3s ease;
    display: flex;
    flex-direction: column;
    box-shadow: 0 0 30px rgba(0,0,0,.1);
  }
  body.bm-mnav-open { overflow: hidden; }
  body.bm-mnav-open .bm-mnav-overlay {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }
  body.bm-mnav-open .bm-mnav-drawer {
    transform: translateX(0);
  }
  .bm-mnav-drawer__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 20px;
    border-bottom: 1px solid #eee;
  }
  .bm-mnav-drawer__title {
    font-family: var(--font-family-second), 'Cormorant Garamond', serif;
    font-size: 20px;
    color: #000;
  }
  .bm-mnav-drawer__close {
    background: transparent;
    border: 0;
    padding: 6px;
    cursor: pointer;
    color: #000;
    display: inline-flex;
  }
  .bm-mnav-drawer__body {
    flex: 1 1 auto;
    overflow-y: auto;
    padding: 8px 0 24px;
  }
  .bm-mnav-list,
  .bm-mnav-sublist {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .bm-mnav-item { border-bottom: 1px solid #f3f3f3; }
  .bm-mnav-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .bm-mnav-link {
    flex: 1;
    padding: 14px 20px;
    color: #000;
    text-decoration: none;
    font-family: var(--font-family-base), 'Manrope', sans-serif;
    font-size: 15px;
    letter-spacing: .3px;
  }
  .bm-mnav-link--child {
    padding-left: 36px;
    font-size: 14px;
    color: #444;
  }
  .bm-mnav-expand {
    background: transparent;
    border: 0;
    padding: 14px 16px;
    cursor: pointer;
    color: #000;
    display: inline-flex;
    transition: transform .25s ease;
  }
  .bm-mnav-item--has-children > .bm-mnav-sublist {
    max-height: 0;
    overflow: hidden;
    transition: max-height .3s ease;
    background: #fafafa;
  }
  .bm-mnav-item.is-open > .bm-mnav-sublist { max-height: 2000px; }
  .bm-mnav-item.is-open > .bm-mnav-row .bm-mnav-expand { transform: rotate(180deg); }

  .bm-mnav-footer {
    display: flex;
    gap: 24px;
    padding: 20px 20px 0;
    border-top: 1px solid #eee;
    margin-top: 12px;
  }
  .bm-mnav-footer a {
    color: #000;
    text-decoration: none;
    font-family: var(--font-family-base), 'Manrope', sans-serif;
    font-size: 14px;
  }
</style>

<script>
(function() {
  if (window.__bmMnavInit) return;
  window.__bmMnavInit = true;

  var body = document.body;

  function openNav()  { body.classList.add('bm-mnav-open'); }
  function closeNav() { body.classList.remove('bm-mnav-open'); }

  document.addEventListener('click', function(e) {
    var openBtn = e.target.closest('[data-bm-mnav-open]');
    if (openBtn) {
      e.preventDefault();
      e.stopPropagation();
      openNav();
      return;
    }
    var closeBtn = e.target.closest('[data-bm-mnav-close]');
    if (closeBtn) {
      e.preventDefault();
      e.stopPropagation();
      closeNav();
      return;
    }
    var expandBtn = e.target.closest('[data-bm-mnav-toggle]');
    if (expandBtn) {
      e.preventDefault();
      e.stopPropagation();
      var item = expandBtn.closest('.bm-mnav-item');
      if (item) item.classList.toggle('is-open');
      return;
    }
  }, true);

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') closeNav();
  });
})();
</script>
