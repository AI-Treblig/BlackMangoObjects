{%- comment -%}
  Black Mango clean product gallery
  Self-contained: own HTML, CSS, JS. No dependencies on theme Swiper.
{%- endcomment -%}

{%- assign featured_media = product.selected_or_first_available_variant.featured_media | default: product.featured_media -%}

<div class="bm-gallery" data-product-id="{{ product.id }}">
  <div class="bm-gallery__thumbs" data-bm-thumbs>
    {%- for media in product.media -%}
      <button type="button"
              class="bm-gallery__thumb{% if media.id == featured_media.id %} is-active{% endif %}"
              data-bm-thumb
              data-index="{{ forloop.index0 }}"
              aria-label="Show image {{ forloop.index }}">
        <img src="{{ media | image_url: width: 160 }}"
             alt="{{ media.alt | escape }}"
             width="80" height="80" loading="lazy">
      </button>
    {%- endfor -%}
  </div>

  <div class="bm-gallery__main">
    <div class="bm-gallery__stage" data-bm-stage>
      {%- for media in product.media -%}
        <div class="bm-gallery__slide{% if media.id == featured_media.id %} is-active{% endif %}"
             data-bm-slide
             data-index="{{ forloop.index0 }}">
          <img src="{{ media | image_url: width: 1200 }}"
               alt="{{ media.alt | escape }}"
               width="{{ media.width }}"
               height="{{ media.height }}"
               loading="{% if forloop.first %}eager{% else %}lazy{% endif %}">
        </div>
      {%- endfor -%}
    </div>

    {%- if product.media.size > 1 -%}
      <button type="button" class="bm-gallery__nav bm-gallery__nav--prev" data-bm-prev aria-label="Previous image">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
      </button>
      <button type="button" class="bm-gallery__nav bm-gallery__nav--next" data-bm-next aria-label="Next image">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
      </button>
    {%- endif -%}
  </div>
</div>

<style>
  .bm-gallery {
    display: flex;
    gap: 16px;
    width: 100%;
  }
  .bm-gallery__thumbs {
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex: 0 0 80px;
    max-height: 600px;
    overflow-y: auto;
  }
  .bm-gallery__thumb {
    width: 80px;
    height: 80px;
    padding: 0;
    border: 1px solid #e5e5e5;
    background: #fff;
    cursor: pointer;
    overflow: hidden;
    transition: border-color .2s ease, opacity .2s ease;
    opacity: .65;
  }
  .bm-gallery__thumb:hover { opacity: 1; }
  .bm-gallery__thumb.is-active {
    border-color: #000;
    opacity: 1;
  }
  .bm-gallery__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .bm-gallery__main {
    position: relative;
    flex: 1 1 auto;
    background: #f9f9f9;
    overflow: hidden;
  }
  .bm-gallery__stage {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
  }
  .bm-gallery__slide {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    transition: opacity .35s ease;
  }
  .bm-gallery__slide.is-active {
    opacity: 1;
    visibility: visible;
  }
  .bm-gallery__slide img {
    max-width: 100%;
    max-height: 100%;
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }
  .bm-gallery__nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 40px;
    height: 40px;
    border: none;
    border-radius: 50%;
    background: #fff;
    color: #000;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 2px 8px rgba(0,0,0,.08);
    z-index: 5;
    transition: background .2s ease, color .2s ease;
  }
  .bm-gallery__nav:hover { background: #000; color: #fff; }
  .bm-gallery__nav--prev { left: 12px; }
  .bm-gallery__nav--next { right: 12px; }
  .bm-gallery__nav[disabled] { opacity: .3; cursor: not-allowed; }
  .bm-gallery__nav[disabled]:hover { background: #fff; color: #000; }

  @media (max-width: 767px) {
    .bm-gallery {
      flex-direction: column-reverse;
      gap: 10px;
    }
    .bm-gallery__thumbs {
      flex-direction: row;
      flex: 0 0 auto;
      max-height: none;
      overflow-x: auto;
      overflow-y: hidden;
    }
    .bm-gallery__thumb {
      flex: 0 0 64px;
      width: 64px;
      height: 64px;
    }
  }
</style>

<script>
(function() {
  function initGallery(root) {
    if (!root || root.dataset.bmInit === '1') return;
    root.dataset.bmInit = '1';

    var slides = root.querySelectorAll('[data-bm-slide]');
    var thumbs = root.querySelectorAll('[data-bm-thumb]');
    var prev = root.querySelector('[data-bm-prev]');
    var next = root.querySelector('[data-bm-next]');
    var total = slides.length;
    if (!total) return;

    var current = 0;
    for (var i = 0; i < slides.length; i++) {
      if (slides[i].classList.contains('is-active')) { current = i; break; }
    }

    function show(index) {
      if (index < 0) index = total - 1;
      if (index >= total) index = 0;
      slides.forEach(function(s, i) { s.classList.toggle('is-active', i === index); });
      thumbs.forEach(function(t, i) { t.classList.toggle('is-active', i === index); });
      current = index;
    }

    if (prev) prev.addEventListener('click', function(e) { e.preventDefault(); e.stopPropagation(); show(current - 1); });
    if (next) next.addEventListener('click', function(e) { e.preventDefault(); e.stopPropagation(); show(current + 1); });

    thumbs.forEach(function(thumb) {
      thumb.addEventListener('click', function(e) {
        e.preventDefault();
        e.stopPropagation();
        var idx = parseInt(thumb.dataset.index, 10);
        if (!isNaN(idx)) show(idx);
      });
    });

    root.tabIndex = 0;
    root.addEventListener('keydown', function(e) {
      if (e.key === 'ArrowLeft') { e.preventDefault(); show(current - 1); }
      if (e.key === 'ArrowRight') { e.preventDefault(); show(current + 1); }
    });
  }

  function init() {
    document.querySelectorAll('.bm-gallery').forEach(initGallery);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
  document.addEventListener('shopify:section:load', init);
})();
</script>
