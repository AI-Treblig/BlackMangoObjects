<details-modal class="header__search-form">
	<div class="search-modal">
		<div class="close-search-form"></div>
		<div class="search-modal__content" tabindex="-1">
			<predictive-search class="search-modal__form">
				<form action="{{ routes.search_url }}" method="get" role="search" class="search search-modal__form">
					<div class="field">
						<div class=search-box>
							<button class="search__button_icon" aria-label="{{ 'general.search.title_search' | t }}"><i class="icon-search"></i></button>
							<input type="hidden" name="type" value="product" />
							<input type="hidden" name="options[prefix]" value="last" />
							<input class="search__input field__input" name="q" value="" placeholder="{{ 'general.search.title_search' | t }}" aria-haspopup="listbox" aria-autocomplete="list" autocomplete="off" autocapitalize="off" spellcheck="false">	
                    	</div>
						{%- if section.settings.show_button_search -%}
						<button class="search__button field__button" aria-label="{{ 'general.search.title_search' | t }}">{{ 'general.search.title' | t }}</button>
						{%- endif -%}
					</div>
					<div class="predictive-search-content" style="display:none">
						<div class="predictive-search predictive-search--header" tabindex="-1" data-predictive-search>
							<div class="predictive-search__loading-state"></div>
						</div>
					</div>
					<span class="predictive-search-status visually-hidden" role="status" aria-hidden="true"></span>
				</form>
			</predictive-search>
		</div>
	</div>
</details-modal>