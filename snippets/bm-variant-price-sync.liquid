{%- comment -%}
  Black Mango — keep the displayed price in sync with the selected variant.
  Self-contained. Format = ₹ + integer with comma thousands (no decimals).
  Includes debug logging so you can see what's happening in the browser console.
{%- endcomment -%}
<script>
(function() {
  var DEBUG = true;
  var log = function() { if (DEBUG && window.console) console.log.apply(console, ['[BM variant]'].concat([].slice.call(arguments))); };

  /* Find ProductJson — accept both scoped and generic IDs */
  var productJsonEl = document.getElementById('ProductJson-{{ section.id }}')
                   || document.querySelector('[id^="ProductJson-"]');
  if (!productJsonEl) { log('no ProductJson script found'); return; }

  var product;
  try { product = JSON.parse(productJsonEl.textContent); }
  catch (e) { log('failed to parse ProductJson:', e); return; }
  if (!product || !product.variants) { log('no variants in product'); return; }

  log('loaded for', product.title, '—', product.variants.length, 'variants');

  function formatINR(cents) {
    var n = Math.round(cents / 100);
    return '₹' + String(n).replace(/\B(?=(\d{3})+(?!\d))/g, ',');
  }

  function selectedValues() {
    var values = [];
    document.querySelectorAll('.js-single-option-selector[type="radio"]:checked').forEach(function(r) {
      var idxStr = (r.dataset.index || 'option1').replace(/option/, '');
      var idx = parseInt(idxStr, 10) - 1;
      if (idx >= 0) values[idx] = r.value;
    });
    document.querySelectorAll('select.js-single-option-selector').forEach(function(s) {
      var idxStr = (s.dataset.index || 'option1').replace(/option/, '');
      var idx = parseInt(idxStr, 10) - 1;
      if (idx >= 0 && values[idx] == null) values[idx] = s.value;
    });
    return values;
  }

  function findVariant() {
    var vals = selectedValues();
    if (!vals.length) return null;
    /* Match a variant whose options match all selected values at the same index */
    for (var i = 0; i < product.variants.length; i++) {
      var v = product.variants[i];
      var ok = true;
      for (var j = 0; j < v.options.length; j++) {
        if (vals[j] == null) continue;
        if (vals[j] !== v.options[j]) { ok = false; break; }
      }
      if (ok) return v;
    }
    return null;
  }

  function update() {
    var v = findVariant();
    if (!v) { log('no matching variant for selection:', selectedValues()); return; }
    log('updating to variant:', v.title, '— price:', v.price, '— compare_at:', v.compare_at_price);

    /* Main price */
    var priceEls = document.querySelectorAll('.js-product-price');
    log('found', priceEls.length, '.js-product-price element(s)');
    priceEls.forEach(function(el) {
      el.innerHTML = formatINR(v.price);
      el.setAttribute('content', (v.price / 100).toFixed(2));
      if (v.compare_at_price && v.compare_at_price > v.price) el.classList.add('on-sale');
      else el.classList.remove('on-sale');
    });

    /* Compare-at price */
    document.querySelectorAll('.js-product-compare-price').forEach(function(el) {
      var wrap = el.closest('.product-single__price--wrapper');
      if (v.compare_at_price && v.compare_at_price > v.price) {
        el.innerHTML = formatINR(v.compare_at_price);
        if (wrap) { wrap.classList.remove('d-none'); wrap.setAttribute('aria-hidden', 'false'); }
      } else {
        el.innerHTML = '';
        if (wrap) { wrap.classList.add('d-none'); wrap.setAttribute('aria-hidden', 'true'); }
      }
    });

    /* Hidden variant ID for Add to Cart */
    var idInput = document.querySelector('form[action*="/cart/add"] input[name="id"]');
    if (idInput) idInput.value = v.id;

    /* URL */
    if (window.history && history.replaceState) {
      try {
        var url = new URL(window.location.href);
        url.searchParams.set('variant', v.id);
        history.replaceState({}, '', url.toString());
      } catch (e) {}
    }
  }

  /* Aggressive event coverage — listen everywhere */
  document.addEventListener('change', update, true);
  document.addEventListener('input',  update, true);
  document.addEventListener('click', function() {
    setTimeout(update, 0);
    setTimeout(update, 80);
    setTimeout(update, 250);
  }, true);

  /* Polling fallback (300ms) — bulletproof if any of the above misses */
  var lastId = null;
  setInterval(function() {
    var v = findVariant();
    if (v && v.id !== lastId) {
      lastId = v.id;
      update();
    }
  }, 300);

  /* Initial sync now and shortly after load */
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', update);
  } else {
    update();
  }
  setTimeout(update, 600);
})();
</script>