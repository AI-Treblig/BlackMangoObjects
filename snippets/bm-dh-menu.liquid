{%- comment -%} Black Mango desktop header menu renderer with dropdowns {%- endcomment -%}
<ul class="bm-dh__menu" style="display: flex; align-items: center; gap: inherit; list-style: none; margin: 0; padding: 0;">
  {%- for link in menu.links -%}
    <li class="bm-dh__menu-item{% if link.links.size > 0 %} bm-dh__menu-item--has-children{% endif %}{% if link.active %} is-active{% endif %}">
      <a class="bm-dh__menu-link" href="{{ link.url }}">
        {{ link.title }}
        {%- if link.links.size > 0 -%}
          <svg class="bm-dh__menu-caret" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="3 4.5 6 7.5 9 4.5"></polyline></svg>
        {%- endif -%}
      </a>
      {%- if link.links.size > 0 -%}
        <div class="bm-dh__dropdown">
          {%- for child in link.links -%}
            <a href="{{ child.url }}">{{ child.title }}</a>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </li>
  {%- endfor -%}
</ul>
