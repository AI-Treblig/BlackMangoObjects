{%- comment -%}
  Black Mango — premium Contact Us section.
  Two-column layout: contact info (left) + send-message form (right).
  Form posts via Shopify {% form 'contact' %} and lands in the store's
  contact email (Settings → General → Store contact email).
{%- endcomment -%}

<section class="bm-contact"
         style="--bc-bg: {{ section.settings.bg_color | default: '#ffffff' }};
                --bc-text: {{ section.settings.text_color | default: '#444444' }};
                --bc-heading: {{ section.settings.heading_color | default: '#000000' }};
                --bc-accent: {{ section.settings.accent_color | default: '#000000' }};
                --bc-card-bg: {{ section.settings.card_bg | default: '#fafafa' }};
                --bc-border: {{ section.settings.border_color | default: '#e5e5e5' }};">
  <div class="bm-contact__container">
    <div class="bm-contact__grid">

      <!-- Left: Info column -->
      <div class="bm-contact__info">
        {%- if section.settings.eyebrow != blank -%}
          <span class="bm-contact__eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h1 class="bm-contact__heading">{{ section.settings.heading }}</h1>
        {%- endif -%}
        {%- if section.settings.intro != blank -%}
          <p class="bm-contact__intro">{{ section.settings.intro }}</p>
        {%- endif -%}

        <div class="bm-contact__cards">
          {%- if section.settings.address != blank -%}
            {%- assign maps_q = section.settings.address | url_encode -%}
            <a href="https://maps.google.com/?q={{ maps_q }}" target="_blank" rel="noopener" class="bm-contact__card">
              <span class="bm-contact__card-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
              </span>
              <span class="bm-contact__card-text">
                <span class="bm-contact__card-title">Address</span>
                <span class="bm-contact__card-value">{{ section.settings.address }}</span>
              </span>
            </a>
          {%- endif -%}

          {%- if section.settings.whatsapp != blank -%}
            {%- assign wa_clean = section.settings.whatsapp | replace: '+', '' | replace: ' ', '' | replace: '-', '' | replace: '(', '' | replace: ')', '' -%}
            <a href="https://wa.me/{{ wa_clean }}{% if section.settings.whatsapp_prefill != blank %}?text={{ section.settings.whatsapp_prefill | url_encode }}{% endif %}" target="_blank" rel="noopener" class="bm-contact__card">
              <span class="bm-contact__card-icon bm-contact__card-icon--wa" aria-hidden="true">
                {%- if section.settings.whatsapp_icon -%}
                  <img src="{{ section.settings.whatsapp_icon | image_url: width: 120 }}" alt="" width="26" height="26">
                {%- else -%}
                  <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor"><path d="M17.6 6.32A7.85 7.85 0 0 0 12.05 4a7.94 7.94 0 0 0-6.88 11.89L4 20l4.22-1.11a7.93 7.93 0 0 0 3.83.98h.01a7.94 7.94 0 0 0 5.54-13.55zm-2 9.61c-.16.46-.94.88-1.34.95-.34.05-.78.07-1.26-.08-.29-.09-.66-.21-1.14-.42-2.01-.87-3.33-2.91-3.43-3.04-.1-.13-.82-1.08-.82-2.06s.52-1.47.7-1.67a.75.75 0 0 1 .54-.25l.39.01c.12 0 .29-.05.45.34.17.4.57 1.38.62 1.48.05.1.09.22.02.35-.07.13-.1.21-.2.33-.1.12-.21.26-.3.35-.1.09-.2.2-.09.4.11.2.51.85 1.12 1.38.76.68 1.4.89 1.6.99.2.1.32.08.43-.05.13-.13.5-.58.62-.78.13-.2.26-.17.45-.1.18.07 1.16.55 1.36.65.2.1.33.15.38.23.05.09.05.49-.11.95z"/></svg>
                {%- endif -%}
              </span>
              <span class="bm-contact__card-text">
                <span class="bm-contact__card-title">WhatsApp</span>
                <span class="bm-contact__card-value">{{ section.settings.whatsapp }}</span>
              </span>
            </a>
          {%- endif -%}

          {%- if section.settings.phone != blank -%}
            {%- assign ph = section.settings.phone | replace: ' ', '' | replace: '-', '' -%}
            <a href="tel:{{ ph }}" class="bm-contact__card">
              <span class="bm-contact__card-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
              </span>
              <span class="bm-contact__card-text">
                <span class="bm-contact__card-title">Phone</span>
                <span class="bm-contact__card-value">{{ section.settings.phone }}</span>
              </span>
            </a>
          {%- endif -%}

          {%- if section.settings.email != blank -%}
            <a href="mailto:{{ section.settings.email }}" class="bm-contact__card">
              <span class="bm-contact__card-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
              </span>
              <span class="bm-contact__card-text">
                <span class="bm-contact__card-title">Email</span>
                <span class="bm-contact__card-value">{{ section.settings.email }}</span>
              </span>
            </a>
          {%- endif -%}

          {%- if section.settings.hours != blank -%}
            <div class="bm-contact__card bm-contact__card--static">
              <span class="bm-contact__card-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
              </span>
              <span class="bm-contact__card-text">
                <span class="bm-contact__card-title">Hours</span>
                <span class="bm-contact__card-value">{{ section.settings.hours }}</span>
              </span>
            </div>
          {%- endif -%}
        </div>

        {%- if section.settings.show_socials -%}
          <div class="bm-contact__socials">
            {%- if section.settings.instagram != blank -%}
              <a href="{{ section.settings.instagram }}" target="_blank" rel="noopener" aria-label="Instagram">
                <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
              </a>
            {%- endif -%}
            {%- if section.settings.facebook != blank -%}
              <a href="{{ section.settings.facebook }}" target="_blank" rel="noopener" aria-label="Facebook">
                <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M22 12a10 10 0 1 0-11.56 9.88v-6.99H7.9V12h2.54V9.8c0-2.5 1.49-3.89 3.77-3.89 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56V12h2.77l-.44 2.89h-2.33v6.99A10 10 0 0 0 22 12z"/></svg>
              </a>
            {%- endif -%}
            {%- if section.settings.pinterest != blank -%}
              <a href="{{ section.settings.pinterest }}" target="_blank" rel="noopener" aria-label="Pinterest">
                <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M12 2a10 10 0 0 0-3.64 19.32c-.09-.77-.16-1.94.03-2.78.18-.76 1.14-4.86 1.14-4.86s-.29-.59-.29-1.45c0-1.36.79-2.38 1.78-2.38.84 0 1.24.63 1.24 1.39 0 .85-.54 2.12-.82 3.3-.23.98.49 1.78 1.46 1.78 1.76 0 3.11-1.85 3.11-4.52 0-2.36-1.7-4.02-4.12-4.02-2.81 0-4.46 2.11-4.46 4.28 0 .85.33 1.76.74 2.25.08.1.09.18.07.28-.08.32-.25 1.01-.28 1.15-.04.18-.15.22-.34.13-1.24-.58-2.02-2.4-2.02-3.86 0-3.14 2.28-6.03 6.58-6.03 3.46 0 6.14 2.47 6.14 5.76 0 3.44-2.17 6.21-5.18 6.21-1.01 0-1.96-.52-2.29-1.14l-.62 2.37c-.22.87-.84 1.96-1.25 2.62A10 10 0 1 0 12 2z"/></svg>
              </a>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>

      <!-- Right: Form column -->
      <div class="bm-contact__form-wrap">
        <div class="bm-contact__form-card">
          <div class="bm-contact__form-head">
            <span class="bm-contact__form-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="36" height="36" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
            </span>
            <h2 class="bm-contact__form-title">{{ section.settings.form_title | default: 'Send us a message' }}</h2>
            {%- if section.settings.form_subtitle != blank -%}
              <p class="bm-contact__form-sub">{{ section.settings.form_subtitle }}</p>
            {%- endif -%}
          </div>

          {%- form 'contact', class: 'bm-contact__form', id: 'bm-contact-form' -%}
            {%- if form.posted_successfully? -%}
              <div class="bm-contact__alert bm-contact__alert--ok">
                {{ section.settings.success_message | default: 'Thank you — your message is on its way. We will get back to you shortly.' }}
              </div>
            {%- endif -%}

            {%- if form.errors -%}
              <div class="bm-contact__alert bm-contact__alert--err">
                {%- for field in form.errors -%}
                  <div>{{ form.errors.messages[field] }}</div>
                {%- endfor -%}
              </div>
            {%- endif -%}

            <div class="bm-contact__row">
              <div class="bm-contact__field">
                <label for="bm-contact-name">Name *</label>
                <input type="text" id="bm-contact-name" name="contact[name]" required
                       value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
                       autocomplete="name" placeholder="Your full name">
              </div>
              <div class="bm-contact__field">
                <label for="bm-contact-email">Email *</label>
                <input type="email" id="bm-contact-email" name="contact[email]" required
                       value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
                       autocomplete="email" placeholder="you@example.com">
              </div>
            </div>

            <div class="bm-contact__row">
              <div class="bm-contact__field bm-contact__field--full">
                <label for="bm-contact-phone">Phone *</label>
                <input type="tel" id="bm-contact-phone" name="contact[phone]" required
                       value="{% if form.phone %}{{ form.phone }}{% elsif customer %}{{ customer.phone }}{% endif %}"
                       autocomplete="tel" placeholder="+91-"
                       pattern="[\d\s+\-()]{7,}"
                       title="Enter a valid phone number">
              </div>
            </div>

            <div class="bm-contact__row">
              <div class="bm-contact__field bm-contact__field--full">
                <label for="bm-contact-message">Message *</label>
                <textarea id="bm-contact-message" name="contact[body]" required rows="5"
                          placeholder="How can we help?"></textarea>
              </div>
            </div>

            <button type="submit" class="bm-contact__submit">
              {{ section.settings.submit_label | default: 'Send message' }}
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
            </button>
          {%- endform -%}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .bm-contact {
    background: var(--bc-bg);
    color: var(--bc-text);
    font-family: var(--font-family-base), 'Manrope', sans-serif;
    padding: {{ section.settings.padding_y | default: 80 }}px 0;
  }
  .bm-contact__container { max-width: 1280px; margin: 0 auto; padding: 0 24px; }
  .bm-contact__grid {
    display: grid;
    grid-template-columns: 1fr 1.15fr;
    gap: 60px;
    align-items: start;
  }

  /* Info column */
  .bm-contact__eyebrow {
    display: inline-block;
    font-size: 11px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--bc-accent);
    margin-bottom: 14px;
  }
  .bm-contact__heading {
    font-family: var(--font-family-second), 'Cormorant Garamond', serif;
    font-size: clamp(36px, 4vw, 56px);
    font-weight: 400;
    line-height: 1.05;
    margin: 0 0 18px;
    color: var(--bc-heading);
  }
  .bm-contact__intro {
    font-size: 15px;
    line-height: 1.7;
    margin: 0 0 36px;
    color: var(--bc-text);
    max-width: 460px;
  }
  .bm-contact__cards {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .bm-contact__card {
    display: flex;
    align-items: center;
    gap: 18px;
    padding: 18px 22px;
    background: var(--bc-card-bg);
    border: 1px solid var(--bc-border);
    text-decoration: none;
    color: inherit;
    transition: transform .25s ease, box-shadow .25s ease, border-color .25s ease;
  }
  .bm-contact__card:hover {
    transform: translateY(-2px);
    border-color: var(--bc-accent);
    box-shadow: 0 12px 28px rgba(0,0,0,.06);
  }
  .bm-contact__card--static { cursor: default; }
  .bm-contact__card--static:hover { transform: none; border-color: var(--bc-border); box-shadow: none; }
  .bm-contact__card-icon {
    flex: 0 0 46px;
    width: 46px;
    height: 46px;
    background: var(--bc-heading);
    color: #fff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    transition: background .25s ease, color .25s ease;
  }
  .bm-contact__card:hover .bm-contact__card-icon { background: var(--bc-accent); }
  /* WhatsApp icon — make uploaded image fill the circle and stay white on hover */
  .bm-contact__card-icon img {
    width: 56%;
    height: 56%;
    object-fit: contain;
    display: block;
    /* If the supplied SVG is dark, invert to white so it shows on the dark circle.
       White-on-transparent SVGs render unchanged. */
    filter: brightness(0) invert(1);
  }
  .bm-contact__card-icon--wa { background: {{ section.settings.whatsapp_icon_bg | default: '#000000' }}; }
  .bm-contact__card:hover .bm-contact__card-icon--wa { background: {{ section.settings.whatsapp_icon_bg_hover | default: section.settings.accent_color | default: '#000000' }}; }
  .bm-contact__card-text { display: flex; flex-direction: column; gap: 2px; }
  .bm-contact__card-title {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 1.8px;
    color: var(--bc-accent);
    font-weight: 600;
  }
  .bm-contact__card-value {
    font-size: 15px;
    color: var(--bc-heading);
    letter-spacing: .3px;
  }
  .bm-contact__socials {
    display: flex;
    gap: 12px;
    margin-top: 28px;
  }
  .bm-contact__socials a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border: 1px solid var(--bc-border);
    border-radius: 50%;
    color: var(--bc-heading);
    transition: background .25s ease, color .25s ease, border-color .25s ease;
  }
  .bm-contact__socials a:hover {
    background: var(--bc-heading);
    color: #fff;
    border-color: var(--bc-heading);
  }

  /* Form column */
  .bm-contact__form-card {
    background: #ffffff;
    padding: 48px 44px;
    box-shadow: 0 28px 70px rgba(0,0,0,.06), 0 2px 6px rgba(0,0,0,.03);
    border: 1px solid var(--bc-border);
  }
  .bm-contact__form-head {
    text-align: center;
    margin-bottom: 32px;
  }
  .bm-contact__form-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 60px;
    height: 60px;
    color: var(--bc-heading);
    background: var(--bc-card-bg);
    border-radius: 50%;
    margin-bottom: 18px;
  }
  .bm-contact__form-title {
    font-family: var(--font-family-second), 'Cormorant Garamond', serif;
    font-size: clamp(26px, 2.4vw, 36px);
    font-weight: 400;
    margin: 0;
    color: var(--bc-heading);
  }
  .bm-contact__form-sub {
    margin: 10px 0 0;
    color: var(--bc-text);
    font-size: 14px;
    line-height: 1.6;
  }
  .bm-contact__alert {
    padding: 14px 18px;
    margin-bottom: 22px;
    font-size: 14px;
    line-height: 1.5;
    border-radius: 2px;
  }
  .bm-contact__alert--ok {
    background: #f0f7f0;
    color: #1e6a1e;
    border-left: 3px solid #1e6a1e;
  }
  .bm-contact__alert--err {
    background: #fbf0f0;
    color: #9a1f1f;
    border-left: 3px solid #9a1f1f;
  }
  .bm-contact__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-bottom: 18px;
  }
  .bm-contact__field { display: flex; flex-direction: column; }
  .bm-contact__field--full { grid-column: 1 / -1; }
  .bm-contact__field label {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 1.8px;
    color: var(--bc-accent);
    font-weight: 600;
    margin-bottom: 8px;
  }
  .bm-contact__field input,
  .bm-contact__field textarea {
    border: 0;
    border-bottom: 1px solid var(--bc-border);
    background: transparent;
    padding: 10px 0;
    font-family: inherit;
    font-size: 15px;
    color: var(--bc-heading);
    outline: none;
    transition: border-color .25s ease;
  }
  .bm-contact__field input:focus,
  .bm-contact__field textarea:focus {
    border-bottom-color: var(--bc-accent);
  }
  .bm-contact__field textarea {
    resize: vertical;
    min-height: 110px;
    border: 1px solid var(--bc-border);
    padding: 12px 14px;
  }
  .bm-contact__field textarea:focus { border-color: var(--bc-accent); }
  .bm-contact__submit {
    margin-top: 22px;
    width: 100%;
    background: var(--bc-heading);
    color: #ffffff;
    border: 1px solid var(--bc-heading);
    padding: 16px 24px;
    font-family: inherit;
    font-size: 13px;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    transition: background .25s ease, color .25s ease;
  }
  .bm-contact__submit:hover {
    background: transparent;
    color: var(--bc-heading);
  }
  .bm-contact__submit svg {
    transition: transform .25s ease;
  }
  .bm-contact__submit:hover svg { transform: translateX(4px); }

  @media (max-width: 991px) {
    .bm-contact { padding: 60px 0; }
    .bm-contact__grid { grid-template-columns: 1fr; gap: 40px; }
    .bm-contact__form-card { padding: 36px 28px; }
  }
  @media (max-width: 600px) {
    .bm-contact { padding: 40px 0; }
    .bm-contact__container { padding: 0 16px; }
    .bm-contact__row { grid-template-columns: 1fr; }
    .bm-contact__card { padding: 14px 16px; gap: 14px; }
    .bm-contact__card-icon { flex: 0 0 40px; width: 40px; height: 40px; }
    .bm-contact__form-card { padding: 30px 22px; }
  }
</style>

{% schema %}
{
  "name": "BM Contact",
  "settings": [
    { "type": "header", "content": "Intro" },
    { "type": "text",  "id": "eyebrow", "label": "Eyebrow", "default": "GET IN TOUCH" },
    { "type": "text",  "id": "heading", "label": "Heading", "default": "Contact Us" },
    { "type": "textarea", "id": "intro", "label": "Intro paragraph",
      "default": "We would love to hear from you. Whether you have a question about a product, an order, or simply want to say hello — our team is here to help." },

    { "type": "header", "content": "Contact info" },
    { "type": "text", "id": "address", "label": "Address", "default": "Mumbai, MH, India" },
    { "type": "text", "id": "whatsapp", "label": "WhatsApp number", "default": "+91 86982 05381", "info": "International format. Auto-links to wa.me." },
    { "type": "image_picker", "id": "whatsapp_icon", "label": "WhatsApp icon (optional)", "info": "Upload or pick a logo (e.g. whatsapp-logo.svg from your media library). Leave empty to use the built-in SVG." },
    { "type": "color", "id": "whatsapp_icon_bg", "label": "WhatsApp circle background", "default": "#000000" },
    { "type": "color", "id": "whatsapp_icon_bg_hover", "label": "WhatsApp circle background (hover)", "default": "#000000" },
    { "type": "textarea", "id": "whatsapp_prefill", "label": "WhatsApp pre-fill message", "default": "Hi! I have a question." },
    { "type": "text", "id": "phone", "label": "Phone (optional)", "info": "Tap-to-call link" },
    { "type": "text", "id": "email", "label": "Email", "default": "info@blackmangoobjects.com" },
    { "type": "text", "id": "hours", "label": "Hours (optional)", "default": "Online store — open 24/7" },

    { "type": "header", "content": "Social links (optional)" },
    { "type": "checkbox", "id": "show_socials", "label": "Show social icons", "default": true },
    { "type": "url", "id": "instagram", "label": "Instagram URL" },
    { "type": "url", "id": "facebook", "label": "Facebook URL" },
    { "type": "url", "id": "pinterest", "label": "Pinterest URL" },

