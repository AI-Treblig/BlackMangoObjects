{%- comment -%}
  Black Mango mobile navigation section.
  Backend controls for logo, menu, and bottom navigation bar.
{%- endcomment -%}

{%- assign menu = linklists[section.settings.menu] -%}
{%- if menu == blank or menu.links.size == 0 -%}
  {%- assign menu = linklists.main-menu -%}
{%- endif -%}

{%- assign logo = section.settings.logo_mobile -%}
{%- assign logo_height = section.settings.logo_height | default: 36 -%}

<div id="bm-mnav-bar" class="bm-mnav-bar">
  <div class="bm-mnav-bar__inner">
    <button type="button"
            id="bm-mnav-open"
            class="bm-mnav-trigger"
            aria-label="Open menu"
            onclick="document.body.classList.add('bm-mnav-open');return false;">
      <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>

    <a class="bm-mnav-logo" href="/" aria-label="{{ shop.name }}">
      {%- if logo -%}
        <img src="{{ logo | image_url: width: 400 }}"
             alt="{{ logo.alt | default: shop.name }}"
             style="height: {{ logo_height }}px; width: auto;">
      {%- else -%}
        <span class="bm-mnav-logo__text">{{ shop.name }}</span>
      {%- endif -%}
    </a>

    {%- if section.settings.show_cart_icon -%}
      <a href="/cart" class="bm-mnav-cart" aria-label="Cart">
        <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path>
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <path d="M16 10a4 4 0 0 1-8 0"></path>
        </svg>
        <span class="bm-mnav-cart__count" data-cart-count>{{ cart.item_count }}</span>
      </a>
    {%- else -%}
      <span class="bm-mnav-spacer"></span>
    {%- endif -%}
  </div>
</div>

<div id="bm-mnav-overlay"
     class="bm-mnav-overlay"
     onclick="document.body.classList.remove('bm-mnav-open')"></div>

<aside id="bm-mnav-drawer" class="bm-mnav-drawer" aria-hidden="true">
  <div class="bm-mnav-drawer__head">
    <span class="bm-mnav-drawer__title">{{ section.settings.drawer_title | default: 'Menu' }}</span>
    <button type="button"
            class="bm-mnav-close"
            aria-label="Close menu"
            onclick="document.body.classList.remove('bm-mnav-open');return false;">
      <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
  </div>

  <nav class="bm-mnav-drawer__body">
    {%- if section.settings.show_search -%}
      <form action="{{ routes.search_url }}" method="get" role="search" class="bm-mnav-search">
        <input type="search" name="q" placeholder="{{ section.settings.search_placeholder | default: 'Search products...' }}" aria-label="Search" autocomplete="off">
        <button type="submit" aria-label="Submit search">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="11" cy="11" r="8"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
          </svg>
        </button>
      </form>
    {%- endif -%}

    <ul class="bm-mnav-list">
      {%- for link in menu.links -%}
        <li class="bm-mnav-item{% if link.links.size > 0 %} bm-mnav-item--has-children{% endif %}">
          <div class="bm-mnav-row">
            <a class="bm-mnav-link" href="{{ link.url }}">{{ link.title }}</a>
            {%- if link.links.size > 0 -%}
              <button type="button"
                      class="bm-mnav-expand"
                      aria-label="Expand {{ link.title | escape }}"
                      onclick="this.closest('.bm-mnav-item').classList.toggle('is-open');return false;">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
              </button>
            {%- endif -%}
          </div>
          {%- if link.links.size > 0 -%}
            <ul class="bm-mnav-sublist">
              {%- for child in link.links -%}
                <li class="bm-mnav-item{% if child.links.size > 0 %} bm-mnav-item--has-children{% endif %}">
                  <div class="bm-mnav-row">
                    <a class="bm-mnav-link bm-mnav-link--child" href="{{ child.url }}">{{ child.title }}</a>
                    {%- if child.links.size > 0 -%}
                      <button type="button"
                              class="bm-mnav-expand"
                              aria-label="Expand {{ child.title | escape }}"
                              onclick="this.closest('.bm-mnav-item').classList.toggle('is-open');return false;">
                        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                          <polyline points="6 9 12 15 18 9"></polyline>
                        </svg>
                      </button>
                    {%- endif -%}
                  </div>
                  {%- if child.links.size > 0 -%}
                    <ul class="bm-mnav-sublist">
                      {%- for grandchild in child.links -%}
                        <li class="bm-mnav-item">
                          <div class="bm-mnav-row">
                            <a class="bm-mnav-link bm-mnav-link--child" href="{{ grandchild.url }}">{{ grandchild.title }}</a>
                          </div>
                        </li>
                      {%- endfor -%}
                    </ul>
                  {%- endif -%}
                </li>
              {%- endfor -%}
            </ul>
          {%- endif -%}
        </li>
      {%- endfor -%}
    </ul>

    {%- if section.settings.instagram_url != blank or section.settings.whatsapp_number != blank -%}
      <div class="bm-mnav-social">
        {%- if section.settings.instagram_url != blank -%}
          <a href="{{ section.settings.instagram_url }}" target="_blank" rel="noopener" aria-label="Instagram">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
            </svg>
            <span>Instagram</span>
          </a>
        {%- endif -%}
        {%- if section.settings.whatsapp_number != blank -%}
          {%- assign wa_clean = section.settings.whatsapp_number | replace: '+', '' | replace: ' ', '' | replace: '-', '' -%}
          <a href="https://wa.me/{{ wa_clean }}" target="_blank" rel="noopener" aria-label="WhatsApp">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path>
            </svg>
            <span>WhatsApp</span>
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- assign cat_blocks = section.blocks | where: 'type', 'category' -%}
    {%- if cat_blocks.size > 0 -%}
      <div class="bm-mnav-cats{% if section.settings.cats_layout == 'scroll' %} bm-mnav-cats--scroll{% endif %}">
        {%- if section.settings.cats_title != blank -%}
          <h3 class="bm-mnav-cats__title">{{ section.settings.cats_title }}</h3>
        {%- endif -%}
        <div class="bm-mnav-cats__grid">
          {%- for block in cat_blocks -%}
            {%- assign cat_url = block.settings.url | default: '#' -%}
            <a href="{{ cat_url }}" class="bm-mnav-cat" {{ block.shopify_attributes }}>
              <span class="bm-mnav-cat__img">
                {%- if block.settings.image -%}
                  <img src="{{ block.settings.image | image_url: width: 240 }}" alt="{{ block.settings.label | escape }}" loading="lazy">
                {%- endif -%}
              </span>
              <span class="bm-mnav-cat__label">{{ block.settings.label }}</span>
            </a>
          {%- endfor -%}
        </div>
      </div>
    {%- elsif section.settings.show_default_categories -%}
      {%- comment -%} Fallback: auto-render from the chosen collection list {%- endcomment -%}
      {%- assign cat_list = linklists[section.settings.categories_menu] -%}
      {%- if cat_list.links.size > 0 -%}
        <div class="bm-mnav-cats{% if section.settings.cats_layout == 'scroll' %} bm-mnav-cats--scroll{% endif %}">
          {%- if section.settings.cats_title != blank -%}
            <h3 class="bm-mnav-cats__title">{{ section.settings.cats_title }}</h3>
          {%- endif -%}
          <div class="bm-mnav-cats__grid">
            {%- for l in cat_list.links limit: 12 -%}
              {%- assign coll = collections[l.handle] -%}
              <a href="{{ l.url }}" class="bm-mnav-cat">
                <span class="bm-mnav-cat__img">
                  {%- if coll.image -%}
                    <img src="{{ coll.image | image_url: width: 240 }}" alt="{{ l.title | escape }}" loading="lazy">
                  {%- elsif coll.products.first.featured_image -%}
                    <img src="{{ coll.products.first.featured_image | image_url: width: 240 }}" alt="{{ l.title | escape }}" loading="lazy">
                  {%- endif -%}
                </span>
                <span class="bm-mnav-cat__label">{{ l.title }}</span>
              </a>
            {%- endfor -%}
          </div>
        </div>
      {%- endif -%}
    {%- endif -%}

    {%- if section.settings.contact_phone != blank or section.settings.contact_email != blank -%}
      <div class="bm-mnav-contact" style="--ct-color: {{ section.settings.contact_color | default: '#444444' }}; --ct-size: {{ section.settings.contact_font_size | default: 13 }}px;">
        {%- if section.settings.contact_phone != blank -%}
          {%- assign phone_clean = section.settings.contact_phone | replace: ' ', '' | replace: '-', '' -%}
          <a href="tel:{{ phone_clean }}">
            {%- case section.settings.phone_icon -%}
              {%- when 'whatsapp' -%}
                <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M17.6 6.32A7.85 7.85 0 0 0 12.05 4a7.94 7.94 0 0 0-6.88 11.89L4 20l4.22-1.11a7.93 7.93 0 0 0 3.83.98h.01a7.94 7.94 0 0 0 5.54-13.55zm-5.55 12.21h-.01a6.6 6.6 0 0 1-3.36-.92l-.24-.14-2.5.66.67-2.44-.16-.25a6.6 6.6 0 1 1 5.6 3.09zm3.62-4.94c-.2-.1-1.17-.58-1.36-.65-.18-.07-.31-.1-.45.1-.13.2-.5.65-.62.78-.11.13-.23.15-.43.05-.2-.1-.84-.31-1.6-.99-.6-.53-1-1.18-1.12-1.38-.11-.2-.01-.31.09-.4.09-.09.2-.23.3-.35.1-.12.13-.2.2-.33.07-.13.03-.25-.02-.35-.05-.1-.45-1.08-.62-1.48-.16-.39-.33-.34-.45-.34l-.39-.01a.75.75 0 0 0-.54.25c-.18.2-.7.69-.7 1.67 0 .98.72 1.93.82 2.06.1.13 1.42 2.17 3.43 3.04.48.21.85.33 1.14.42.48.15.92.13 1.26.08.39-.06 1.17-.48 1.34-.95.16-.46.16-.86.11-.95-.05-.08-.18-.13-.38-.23z"/></svg>
              {%- when 'mobile' -%}
                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"></rect><line x1="12" y1="18" x2="12" y2="18"></line></svg>
              {%- else -%}
                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
            {%- endcase -%}
            <span>{{ section.settings.contact_phone }}</span>
          </a>
        {%- endif -%}
        {%- if section.settings.contact_email != blank -%}
          <a href="mailto:{{ section.settings.contact_email }}">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
              <polyline points="22,6 12,13 2,6"></polyline>
            </svg>
            <span>{{ section.settings.contact_email }}</span>
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}
  </nav>
</aside>

{%- assign bottom_blocks = section.blocks | where: 'type', 'bottom_link' -%}
{%- if section.settings.show_bottom_bar and bottom_blocks.size > 0 -%}
  <nav id="bm-mnav-bottom" class="bm-mnav-bottom" aria-label="Mobile bottom navigation">
    {%- for block in bottom_blocks -%}
      {%- assign icon = block.settings.icon -%}
      {%- assign label = block.settings.label -%}
      {%- assign default_url = '/' -%}
      {%- case icon -%}
        {%- when 'home' -%}{%- assign default_url = '/' -%}
        {%- when 'shop' -%}{%- assign default_url = routes.all_products_collection_url -%}
        {%- when 'account' -%}{%- assign default_url = routes.account_url -%}
        {%- when 'wishlist' -%}{%- assign default_url = '/pages/wishlist' -%}
        {%- when 'cart' -%}{%- assign default_url = routes.cart_url -%}
        {%- when 'search' -%}{%- assign default_url = routes.search_url -%}
      {%- endcase -%}
      {%- assign link_url = block.settings.url | default: default_url -%}
      <a href="{{ link_url }}" class="bm-mnav-bottom__item" aria-label="{{ label | escape }}" {{ block.shopify_attributes }}>
        <span class="bm-mnav-bottom__icon">
          {%- case icon -%}
            {%- when 'home' -%}
              <svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
            {%- when 'shop' -%}
              <svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect></svg>
            {%- when 'account' -%}
              <svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
            {%- when 'wishlist' -%}
              <span class="bm-mnav-bottom__icon-wrap">
                <svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
                <span class="bm-mnav-bottom__badge" data-count-wishlist>0</span>
              </span>
            {%- when 'cart' -%}
              <span class="bm-mnav-bottom__icon-wrap">
                <svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path><line x1="3" y1="6" x2="21" y2="6"></line><path d="M16 10a4 4 0 0 1-8 0"></path></svg>
                <span class="bm-mnav-bottom__badge" data-cart-count>{{ cart.item_count }}</span>
              </span>
            {%- when 'search' -%}
              <svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
            {%- when 'menu' -%}
              <svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
          {%- endcase -%}
        </span>
        <span class="bm-mnav-bottom__label">{{ label }}</span>
      </a>
    {%- endfor -%}
  </nav>
{%- endif -%}

<style>
  /* Hide stock theme mobile UI to prevent duplicate UI */
  @media (max-width: 991px) {
    .header-mobile,
    .menu-mobile,
    .header-top-mobile,
    .header-bottom-fixed { display: none !important; }
  }

  /* Top bar: visible only below 992px */
  #bm-mnav-bar { display: none; }
  @media (max-width: 991px) {
    #bm-mnav-bar {
      display: block !important;
      position: fixed !important;
      top: 0 !important;
      left: 0 !important;
      right: 0 !important;
      z-index: 9990 !important;
      background: {{ section.settings.bar_bg | default: '#ffffff' }} !important;
      border-bottom: 1px solid #eee !important;
      width: 100% !important;
    }
    body { padding-top: 60px !important; padding-bottom: {% if section.settings.show_bottom_bar %}72px{% else %}0{% endif %} !important; }
  }

  .bm-mnav-bar__inner {
    display: flex !important;
    align-items: center !important;
    justify-content: space-between !important;
    padding: 10px 16px !important;
    min-height: 56px !important;
  }
  .bm-mnav-trigger,
  .bm-mnav-cart {
    background: transparent;
    border: 0;
    padding: 8px;
    margin: 0;
    cursor: pointer;
    color: {{ section.settings.icon_color | default: '#000000' }};
    display: inline-flex;
    align-items: center;
    justify-content: center;
    position: relative;
    text-decoration: none;
    -webkit-tap-highlight-color: transparent;
  }
  .bm-mnav-spacer { width: 38px; display: inline-block; }
  .bm-mnav-cart__count {
    position: absolute;
    top: 2px;
    right: 2px;
    background: #000;
    color: #fff;
    border-radius: 999px;
    font-size: 10px;
    line-height: 1;
    padding: 3px 5px;
    min-width: 16px;
    text-align: center;
    font-family: var(--font-family-base), 'Manrope', sans-serif;
  }
  .bm-mnav-logo {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    color: #000;
  }
  .bm-mnav-logo img { display: block; }
  .bm-mnav-logo__text {
    font-family: var(--font-family-second), 'Cormorant Garamond', serif;
    font-size: 22px;
    color: #000;
  }

  /* Overlay */
  #bm-mnav-overlay {
    position: fixed !important;
    inset: 0 !important;
    background: rgba(0,0,0,.5) !important;
    z-index: 9998 !important;
    opacity: 0 !important;
    visibility: hidden !important;
    pointer-events: none !important;
    transition: opacity .25s ease !important;
  }
  body.bm-mnav-open #bm-mnav-overlay {
    opacity: 1 !important;
    visibility: visible !important;
    pointer-events: auto !important;
  }

  /* Drawer */
  #bm-mnav-drawer {
    position: fixed !important;
    top: 0 !important;
    left: 0 !important;
    height: 100vh !important;
    width: min(86vw, 360px) !important;
    background: #fff !important;
    z-index: 9999 !important;
    transform: translateX(-100%) !important;
    transition: transform .3s ease !important;
    display: flex !important;
    flex-direction: column !important;
    box-shadow: 0 0 30px rgba(0,0,0,.1) !important;
    visibility: visible !important;
    opacity: 1 !important;
    margin: 0 !important;
    padding: 0 !important;
  }
  body.bm-mnav-open #bm-mnav-drawer { transform: translateX(0) !important; }
  body.bm-mnav-open { overflow: hidden !important; }

  .bm-mnav-drawer__head {
    display: flex !important;
    align-items: center !important;
    justify-content: space-between !important;
    padding: 16px 20px !important;
    border-bottom: 1px solid #eee !important;
  }
  .bm-mnav-drawer__title {
    font-family: var(--font-family-second), 'Cormorant Garamond', serif;
    font-size: 20px;
    color: #000;
  }
  .bm-mnav-close {
    background: transparent;
    border: 0;
    padding: 6px;
    cursor: pointer;
    color: #000;
    display: inline-flex;
    -webkit-tap-highlight-color: transparent;
  }
  .bm-mnav-drawer__body {
    flex: 1 1 auto !important;
    overflow-y: auto !important;
    padding: 8px 0 24px !important;
  }
  .bm-mnav-list,
  .bm-mnav-sublist {
    list-style: none !important;
    margin: 0 !important;
    padding: 0 !important;
  }
  .bm-mnav-item { border-bottom: 1px solid #f3f3f3; }
  .bm-mnav-row { display: flex; align-items: center; justify-content: space-between; }
  .bm-mnav-link {
    flex: 1;
    padding: 14px 20px;
    color: #000;
    text-decoration: none;
    font-family: var(--font-family-base), 'Manrope', sans-serif;
    font-size: 15px;
    letter-spacing: .3px;
  }
  .bm-mnav-link--child { padding-left: 36px; font-size: 14px; color: #444; }
  .bm-mnav-expand {
    background: transparent;
    border: 0;
    padding: 14px 16px;
    cursor: pointer;
    color: #000;
    display: inline-flex;
    transition: transform .25s ease;
    -webkit-tap-highlight-color: transparent;
  }
  .bm-mnav-item--has-children > .bm-mnav-sublist {
    max-height: 0;
    overflow: hidden;
    transition: max-height .3s ease;
    background: #fafafa;
  }
  .bm-mnav-item.is-open > .bm-mnav-sublist { max-height: 2000px; }
  .bm-mnav-item.is-open > .bm-mnav-row .bm-mnav-expand { transform: rotate(180deg); }

  /* Bottom navigation bar */
  #bm-mnav-bottom { display: none; }
  @media (max-width: 991px) {
    #bm-mnav-bottom {
      display: flex !important;
      position: fixed !important;
      bottom: 0 !important;
      left: 0 !important;
      right: 0 !important;
      z-index: 9989 !important;
      background: {{ section.settings.bottom_bar_bg | default: '#ffffff' }} !important;
      border-top: 1px solid #eee !important;
      padding: 8px 4px !important;
      align-items: center !important;
      justify-content: space-around !important;
      padding-bottom: calc(8px + env(safe-area-inset-bottom)) !important;
    }
  }
  .bm-mnav-bottom__item {
    flex: 1 1 0;
    display: flex !important;
    flex-direction: column !important;
    align-items: center !important;
    justify-content: center !important;
    text-decoration: none !important;
    color: {{ section.settings.bottom_icon_color | default: '#000000' }} !important;
    padding: 4px 0;
    gap: 4px;
    -webkit-tap-highlight-color: transparent;
  }
  .bm-mnav-bottom__icon { display: inline-flex; position: relative; }
  .bm-mnav-bottom__label {
    font-family: var(--font-family-base), 'Manrope', sans-serif;
    font-size: 11px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: inherit;
  }
  .bm-mnav-bottom__icon-wrap { position: relative; display: inline-flex; }
  .bm-mnav-bottom__badge {
    position: absolute;
    top: -6px;
    right: -10px;
    background: #000;
    color: #fff;
    border-radius: 999px;
    font-size: 10px;
    line-height: 1;
    padding: 3px 5px;
    min-width: 18px;
    text-align: center;
    font-family: var(--font-family-base), 'Manrope', sans-serif;
  }

  /* Search bar in drawer */
  .bm-mnav-search {
    display: flex;
    align-items: center;
    margin: 16px 20px;
    border: 1px solid #e5e5e5;
    border-radius: 999px;
    overflow: hidden;
    background: #fafafa;
  }
  .bm-mnav-search input {
    flex: 1;
    border: 0;
    background: transparent;
    padding: 10px 14px;
    font-family: var(--font-family-base), 'Manrope', sans-serif;
    font-size: 14px;
    outline: none;
    color: #000;
  }
  .bm-mnav-search button {
    background: transparent;
    border: 0;
    padding: 8px 12px;
    cursor: pointer;
    color: #000;
    display: inline-flex;
    align-items: center;
  }

  /* Social icons */
  .bm-mnav-social {
    display: flex;
    gap: 12px;
    padding: 18px 20px 8px;
    margin-top: 8px;
    border-top: 1px solid #f0f0f0;
  }
  .bm-mnav-social a {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 12px;
    border: 1px solid #e5e5e5;
    border-radius: 999px;
    color: #000;
    text-decoration: none;
    font-family: var(--font-family-base), 'Manrope', sans-serif;
    font-size: 12px;
    letter-spacing: 1px;
    text-transform: uppercase;
    transition: background .2s ease, color .2s ease;
  }
  .bm-mnav-social a:hover { background: #000; color: #fff; }
  .bm-mnav-social a:hover svg { color: #fff; }

  /* Category circles */
  .bm-mnav-cats { padding: 18px 20px 8px; border-top: 1px solid #f0f0f0; }
  .bm-mnav-cats__title {
    font-family: var(--font-family-second), 'Cormorant Garamond', serif;
    font-size: {{ section.settings.cats_title_size | default: 16 }}px;
    margin: 0 0 14px;
    color: {{ section.settings.cats_title_color | default: '#000000' }};
    letter-spacing: 1px;
    text-transform: uppercase;
  }
  .bm-mnav-cats__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px 10px;
  }
  .bm-mnav-cats--scroll .bm-mnav-cats__grid {
    display: grid;
    grid-auto-flow: column;
    grid-template-rows: repeat(2, auto);
    grid-template-columns: none;
    overflow-x: auto;
    overflow-y: hidden;
    gap: 14px 16px;
    padding-bottom: 6px;
    -webkit-overflow-scrolling: touch;
    scroll-snap-type: x mandatory;
  }
  .bm-mnav-cats--scroll .bm-mnav-cat {
    min-width: 80px;
    scroll-snap-align: start;
  }
  .bm-mnav-cat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    text-decoration: none;
    color: inherit;
    -webkit-tap-highlight-color: transparent;
  }
  .bm-mnav-cat__img {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    border: 1px solid {{ section.settings.cat_border_color | default: '#dddddd' }};
    background: {{ section.settings.cat_bg_color | default: '#ffffff' }};
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .bm-mnav-cat__img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .bm-mnav-cat__label {
    font-family: var(--font-family-base), 'Manrope', sans-serif;
    font-size: {{ section.settings.cat_label_size | default: 12 }}px;
    color: {{ section.settings.cat_label_color | default: '#000000' }};
    text-transform: uppercase;
    letter-spacing: .8px;
    text-align: center;
  }

  /* Override menu link font + color from settings */
  .bm-mnav-link {
    font-size: {{ section.settings.menu_font_size | default: 15 }}px !important;
    color: {{ section.settings.menu_color | default: '#000000' }} !important;
  }
  .bm-mnav-link--child {
    color: {{ section.settings.menu_child_color | default: '#444444' }} !important;
  }
  .bm-mnav-drawer__title {
    font-size: {{ section.settings.drawer_title_size | default: 20 }}px !important;
    color: {{ section.settings.drawer_title_color | default: '#000000' }} !important;
  }

  /* Contact info */
  .bm-mnav-contact {
    padding: 12px 20px 24px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .bm-mnav-contact a {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--ct-color, #444);
    text-decoration: none;
    font-family: var(--font-family-base), 'Manrope', sans-serif;
    font-size: var(--ct-size, 13px);
    transition: opacity .2s ease;
  }
  .bm-mnav-contact a:hover { opacity: .7; }
</style>

{% schema %}
{
  "name": "BM Mobile Navigation",
  "settings": [
    { "type": "header", "content": "Top bar" },
    { "type": "image_picker", "id": "logo_mobile", "label": "Mobile logo" },
    { "type": "range", "id": "logo_height", "label": "Logo height (px)", "min": 20, "max": 80, "step": 2, "default": 36 },
    { "type": "color", "id": "bar_bg", "label": "Top bar background", "default": "#ffffff" },
    { "type": "color", "id": "icon_color", "label": "Top bar icon color", "default": "#000000" },
    { "type": "checkbox", "id": "show_cart_icon", "label": "Show cart icon in top bar", "default": false, "info": "Disable if you use the bottom bar for cart." },

    { "type": "header", "content": "Slide-out menu (hamburger)" },
    { "type": "link_list", "id": "menu", "label": "Menu", "default": "main-menu", "info": "Pick the menu shown inside the hamburger drawer. Edit items in Online Store → Navigation." },
    { "type": "text", "id": "drawer_title", "label": "Drawer title", "default": "MENU" },
    { "type": "range", "id": "drawer_title_size", "label": "Drawer title font size (px)", "min": 14, "max": 32, "step": 1, "default": 20 },
    { "type": "color", "id": "drawer_title_color", "label": "Drawer title color", "default": "#000000" },
    { "type": "range", "id": "menu_font_size", "label": "Menu item font size (px)", "min": 12, "max": 22, "step": 1, "default": 15 },
    { "type": "color", "id": "menu_color", "label": "Menu item color", "default": "#000000" },
    { "type": "color", "id": "menu_child_color", "label": "Sub-menu item color", "default": "#444444" },
    { "type": "checkbox", "id": "show_search", "label": "Show search bar in drawer", "default": true },
    { "type": "text", "id": "search_placeholder", "label": "Search placeholder", "default": "Search products..." },

    { "type": "header", "content": "Social links (shown in drawer)" },
    { "type": "url", "id": "instagram_url", "label": "Instagram URL", "info": "e.g. https://instagram.com/yourhandle" },
    { "type": "text", "id": "whatsapp_number", "label": "WhatsApp number", "info": "International format, e.g. 919876543210 (no plus or spaces)" },

    { "type": "header", "content": "Category circles (drawer)", "info": "Add a 'Category icon' block for each circle, OR enable the menu-driven fallback below." },
    { "type": "checkbox", "id": "show_default_categories", "label": "Auto-show categories from a menu", "default": true, "info": "When you have no Category icon blocks, pull categories from the menu chosen below. Each menu item is shown as a circle using its linked collection's image." },
    { "type": "link_list", "id": "categories_menu", "label": "Categories menu (fallback)", "default": "main-menu", "info": "Used only when there are no Category icon blocks." },
    { "type": "text", "id": "cats_title", "label": "Section title (optional)", "default": "" },
    { "type": "range", "id": "cats_title_size", "label": "Title font size (px)", "min": 12, "max": 24, "step": 1, "default": 16 },
    { "type": "color", "id": "cats_title_color", "label": "Title color", "default": "#000000" },
    { "type": "select", "id": "cats_layout", "label": "Layout",
      "options": [
        { "value": "grid", "label": "3-column grid (wraps to multiple rows)" },
        { "value": "scroll", "label": "Horizontal scroll (2 rows)" }
      ],
      "default": "grid",
      "info": "Switch to horizontal scroll when you have many categories."
    },
    { "type": "range", "id": "cat_label_size", "label": "Category label font size (px)", "min": 9, "max": 16, "step": 1, "default": 12 },
    { "type": "color", "id": "cat_label_color", "label": "Category label color", "default": "#000000" },
    { "type": "color", "id": "cat_border_color", "label": "Category circle border", "default": "#dddddd" },
    { "type": "color", "id": "cat_bg_color", "label": "Category circle background", "default": "#ffffff" },

    { "type": "header", "content": "Contact info (shown at bottom of drawer)" },
    { "type": "select", "id": "phone_icon", "label": "Phone icon style",
      "options": [
        { "value": "phone", "label": "Telephone (landline)" },
        { "value": "mobile", "label": "Mobile phone" },
        { "value": "whatsapp", "label": "WhatsApp speech bubble" }
      ],
      "default": "phone"
    },
    { "type": "text", "id": "contact_phone", "label": "Phone number", "info": "Shown as a tap-to-call link" },
    { "type": "text", "id": "contact_email", "label": "Email address", "info": "Shown as a tap-to-email link" },
    { "type": "range", "id": "contact_font_size", "label": "Contact font size (px)", "min": 10, "max": 18, "step": 1, "default": 13 },
    { "type": "color", "id": "contact_color", "label": "Contact text/icon color", "default": "#444444" },

    { "type": "header", "content": "Bottom bar" },
    { "type": "checkbox", "id": "show_bottom_bar", "label": "Enable bottom bar on mobile", "default": true },
    { "type": "color", "id": "bottom_bar_bg", "label": "Bottom bar background", "default": "#ffffff" },
    { "type": "color", "id": "bottom_icon_color", "label": "Bottom bar icon/text color", "default": "#000000" }
  ],
  "blocks": [
    {
      "type": "bottom_link",
      "name": "Bottom bar link",
      "settings": [
        { "type": "select", "id": "icon", "label": "Icon",
          "options": [
            { "value": "home", "label": "Home" },
            { "value": "shop", "label": "Shop / Grid" },
            { "value": "account", "label": "Account" },
            { "value": "wishlist", "label": "Wishlist (heart with count)" },
            { "value": "cart", "label": "Cart (bag with count)" },
            { "value": "search", "label": "Search" },
            { "value": "menu", "label": "Menu" }
          ],
          "default": "home"
        },
        { "type": "text", "id": "label", "label": "Label", "default": "Home" },
        { "type": "url", "id": "url", "label": "URL" }
      ]
    },
    {
      "type": "category",
      "name": "Category icon (drawer)",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image", "info": "Square works best (e.g. 240×240)." },
        { "type": "text", "id": "label", "label": "Label", "default": "Category" },
        { "type": "url", "id": "url", "label": "Link to collection or page" }
      ]
    }
  ],
  "default": {
    "blocks": [
      { "type": "bottom_link", "settings": { "icon": "home",     "label": "Home"     } },
      { "type": "bottom_link", "settings": { "icon": "shop",     "label": "Shop"     } },
      { "type": "bottom_link", "settings": { "icon": "account",  "label": "Account"  } },
      { "type": "bottom_link", "settings": { "icon": "wishlist", "label": "Wishlist" } },
      { "type": "category",    "settings": { "label": "Rugs"     } },
      { "type": "category",    "settings": { "label": "Curtains" } },
      { "type": "category",    "settings": { "label": "Objects"  } },
      { "type": "category",    "settings": { "label": "Cushions" } },
      { "type": "category",    "settings": { "label": "Throws"   } },
      { "type": "category",    "settings": { "label": "More"     } }
    ]
  }
}
{% endschema %}
