{%- assign heading = section.settings.heading | default: 'You May Also Like' -%}
{%- assign limit = section.settings.limit | default: 8 -%}

{%- assign source_collection = nil -%}
{%- if product.collections.size > 0 -%}
  {%- assign source_collection = product.collections | first -%}
{%- endif -%}

{%- assign related = '' | split: '' -%}
{%- if source_collection -%}
  {%- for p in source_collection.products -%}
    {%- if p.id != product.id -%}
      {%- assign related = related | concat: p -%}
      {%- if related.size >= limit -%}{%- break -%}{%- endif -%}
    {%- endif -%}
  {%- endfor -%}
{%- endif -%}

{%- if related.size < limit -%}
  {%- for p in collections.all.products -%}
    {%- unless p.id == product.id -%}
      {%- assign already_in = false -%}
      {%- for existing in related -%}
        {%- if existing.id == p.id -%}{%- assign already_in = true -%}{%- break -%}{%- endif -%}
      {%- endfor -%}
      {%- unless already_in -%}
        {%- assign related = related | concat: p -%}
        {%- if related.size >= limit -%}{%- break -%}{%- endif -%}
      {%- endunless -%}
    {%- endunless -%}
  {%- endfor -%}
{%- endif -%}

{%- if related.size > 0 -%}
<section class="bm-related" style="margin: {{ section.settings.margin }};">
  <div class="container">
    <div class="bm-related__head">
      <h2 class="bm-related__heading">{{ heading }}</h2>
    </div>
    <div class="bm-related__grid">
      {%- for p in related -%}
        <a href="{{ p.url }}" class="bm-related__card">
          <div class="bm-related__image">
            {%- if p.featured_image -%}
              <img src="{{ p.featured_image | image_url: width: 600 }}"
                   alt="{{ p.featured_image.alt | escape }}"
                   width="300" height="300" loading="lazy">
            {%- endif -%}
          </div>
          <div class="bm-related__info">
            <div class="bm-related__title">{{ p.title }}</div>
            <div class="bm-related__price">{{ p.price | money }}</div>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .bm-related { padding: 40px 0; }
  .bm-related__head { text-align: center; margin-bottom: 40px; }
  .bm-related__heading {
    font-family: var(--font-family-second), 'Cormorant Garamond', serif;
    font-size: 32px;
    font-weight: 400;
    margin: 0;
    color: #000;
  }
  .bm-related__grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns | default: 4 }}, 1fr);
    gap: 24px;
  }
  .bm-related__card {
    text-decoration: none;
    color: inherit;
    display: block;
    transition: transform .3s ease;
  }
  .bm-related__card:hover { transform: translateY(-4px); }
  .bm-related__image {
    aspect-ratio: 1 / 1;
    background: #f5f5f5;
    overflow: hidden;
    margin-bottom: 12px;
  }
  .bm-related__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform .5s ease;
  }
  .bm-related__card:hover .bm-related__image img { transform: scale(1.04); }
  .bm-related__info {
    text-align: center;
  }
  .bm-related__title {
    font-family: var(--font-family-second), 'Cormorant Garamond', serif;
    font-size: 18px;
    font-weight: 400;
    margin-bottom: 4px;
    color: #000;
  }
  .bm-related__price {
    font-family: var(--font-family-base), 'Manrope', sans-serif;
    font-size: 14px;
    color: #666;
  }
  @media (max-width: 991px) {
    .bm-related__grid { grid-template-columns: repeat(3, 1fr); gap: 16px; }
  }
  @media (max-width: 767px) {
    .bm-related__grid { grid-template-columns: repeat(2, 1fr); gap: 12px; }
    .bm-related__heading { font-size: 26px; }
  }
</style>
{%- endif -%}

{% schema %}
{
  "name": "BM Related Products",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "You May Also Like" },
    { "type": "range", "id": "limit", "label": "Number of products", "min": 2, "max": 12, "step": 1, "default": 8 },
    { "type": "range", "id": "columns", "label": "Columns (desktop)", "min": 2, "max": 6, "step": 1, "default": 4 },
    { "type": "text", "id": "margin", "label": "Margin", "default": "60px 0" }
  ],
  "presets": [{ "name": "BM Related Products" }]
}
{% endschema %}
