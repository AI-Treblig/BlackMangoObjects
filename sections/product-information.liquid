{%- assign full_description 	= product.description -%}
<section class="product-more-info {{ section.settings.tab_layout }}" style="margin:{{ section.settings.margin }}">
	<div class="product-more-info__inner">
		{%- if section.settings.tab_layout == 'full-content' -%}
			<div class="container">
				<div class="more-info-tabs__content tab-content">
					{%- for block in section.blocks -%}
						{%- case block.type -%}
							{%- when '@app' -%}
                                          {% render block %}
							{%- when 'tab_review' -%}
								<h3 class="more-info-tabs__nav-item">
									{{ block.settings.title_review }}
								</h3>
								<div class="more-tab-container">
									<div class="more-info-tabs__nav-link mobile" data-id="js-more-info-tabs-{{ forloop.index }}">
										<span>{{ block.settings.title_review }}</span>
									</div>
									<!-- Start of Judge.me code --> 
									<div style='clear:both'></div> 
									<div id='judgeme_product_reviews' class='jdgm-widget jdgm-review-widget' data-product-title='{{ product.title | escape }}' data-id='{{ product.id }}' data-auto-install='false'> 
										{{ product.metafields.judgeme.widget }} 
									</div> 
									<!-- End of Judge.me code -->
								</div>
							{%- when 'tab_custom' -%}
								<h3 class="more-info-tabs__nav-item">
									{{ block.settings.title_custom }}
								</h3>
								<div class="more-tab-container">
									<div class="more-info-tabs__nav-link mobile" data-id="js-more-info-tabs-{{ forloop.index }}">
										<span>{{ block.settings.title_custom }}</span>
									</div>
									<div id="js-more-info-tabs-{{ forloop.index }}" class="tab-pane fade {{ classes }}">
										<div class="rte">{{ block.settings.content_custom }}</div>
									</div>
								</div>
						{%- endcase -%}
					{%- endfor -%}
				</div>
			</div>
		{%- else -%}
			<div class="container">
				<div class="content-ul-tab">
					<ul class="more-info-tabs__nav nav">
						{%- for block in section.blocks -%}
							{%- capture "classes" -%}
								{%- if forloop.first -%}
									active
								{%- endif -%}
							{%- endcapture %}
							{%- case block.type -%}
								{%- when '@app' -%}
                                          {% render block %}
								{%- when 'tab_review' -%}
									<li class="more-info-tabs__nav-item">
										<div class="more-info-tabs__nav-link {{ classes }}" data-id="js-more-info-tabs-{{ forloop.index }}">
											<span>{{ block.settings.title_review }}</span>
										</div>
									</li>
								{%- when 'tab_custom' -%}
									<li class="more-info-tabs__nav-item">
										<div class="more-info-tabs__nav-link {{ classes }}" data-id="js-more-info-tabs-{{ forloop.index }}">
											<span>{{ block.settings.title_custom }}</span>
										</div>
									</li>
							{%- endcase -%}
						{%- endfor -%}
					</ul>
				</div>
			</div>
			<div class="container">
				<div class="more-info-tabs__content tab-content">
					{%- for block in section.blocks -%}
						{%- capture "classes" -%}
							{%- if forloop.first -%}
								show
							{%- endif -%}
						{%- endcapture %}
						{%- case block.type -%}
							{%- when '@app' -%}
                                          {% render block %}
							{%- when 'tab_review' -%}
								<div class="more-tab-container">
									<div class="more-info-tabs__nav-link mobile" data-id="js-more-info-tabs-{{ forloop.index }}">
										<span>{{ block.settings.title_review }}</span>
									</div>
									<div id="js-more-info-tabs-{{ forloop.index }}" class="tab-pane fade {{ classes }}">
										<!-- Start of Judge.me code --> 
										<div style='clear:both'></div> 
										<div id='judgeme_product_reviews' class='jdgm-widget jdgm-review-widget' data-product-title='{{ product.title | escape }}' data-id='{{ product.id }}' data-auto-install='false'> 
											{{ product.metafields.judgeme.widget }} 
										</div> 
										<!-- End of Judge.me code -->

									</div>
								</div>
							{%- when 'tab_custom' -%}
								<div class="more-tab-container">
									<div class="more-info-tabs__nav-link mobile" data-id="js-more-info-tabs-{{ forloop.index }}">
										<span>{{ block.settings.title_custom }}</span>
									</div>
									<div id="js-more-info-tabs-{{ forloop.index }}" class="tab-pane fade {{ classes }}">
										<div class="rte">{{ block.settings.content_custom }}</div>
									</div>
								</div>
						{%- endcase -%}
					{%- endfor -%}
				</div>
			</div>
		{%- endif -%}
	</div>
</section>

<style>
  .more-info-tabs__content .tab-pane {
    display: none;
  }
  .more-info-tabs__content .tab-pane.show {
    display: block;
  }
  .more-info-tabs__nav-link {
    cursor: pointer;
    position: relative;
    user-select: none;
  }
  /* Mobile accordion headers — visible only on mobile */
  .more-info-tabs__nav-link.mobile { display: none; }
  @media (max-width: 991px) {
    .product-more-info .more-info-tabs__nav { display: none !important; }
    .product-more-info .more-info-tabs__content .tab-pane { display: none; }
    .product-more-info .more-info-tabs__content .tab-pane.show { display: block; }
    .more-info-tabs__nav-link.mobile {
      display: flex !important;
      align-items: center;
      justify-content: space-between;
      padding: 16px 18px;
      background: #f6f6f6;
      border: 1px solid #ececec;
      margin: 0 0 10px;
      font-family: var(--font-family-base), 'Manrope', sans-serif;
      font-size: 14px;
      letter-spacing: 1px;
      text-transform: uppercase;
      color: #000;
    }
    .more-info-tabs__nav-link.mobile::after {
      content: '+';
      font-size: 22px;
      line-height: 1;
      font-weight: 300;
      transition: transform .2s ease;
    }
    .more-info-tabs__nav-link.mobile.active::after { content: '–'; }
    .more-tab-container { margin-bottom: 6px; }
    .more-tab-container .tab-pane {
      padding: 16px 18px 24px;
      border: 1px solid #ececec;
      border-top: none;
      margin-top: -10px;
      margin-bottom: 10px;
    }
  }
</style>

<script>
(function() {
  if (window.__bmTabsInit) return;
  window.__bmTabsInit = true;

  function closeAll(container) {
    container.querySelectorAll('.tab-pane').forEach(function(p) { p.classList.remove('show'); });
    container.querySelectorAll('.more-info-tabs__nav-link').forEach(function(t) { t.classList.remove('active'); });
  }

  document.addEventListener('click', function(e) {
    var trigger = e.target.closest('.more-info-tabs__nav-link');
    if (!trigger) return;
    e.preventDefault();
    e.stopPropagation();

    var targetId = trigger.getAttribute('data-id');
    if (!targetId) return;
    var pane = document.getElementById(targetId);
    if (!pane) return;

    var section = trigger.closest('.product-more-info');
    if (!section) return;

    var isMobile = trigger.classList.contains('mobile');
    var wasOpen = pane.classList.contains('show');

    if (isMobile) {
      closeAll(section);
      if (!wasOpen) {
        pane.classList.add('show');
        trigger.classList.add('active');
        var mobileHeader = section.querySelector('.more-info-tabs__nav-link.mobile[data-id="' + targetId + '"]');
        if (mobileHeader) mobileHeader.classList.add('active');
      }
    } else {
      closeAll(section);
      pane.classList.add('show');
      section.querySelectorAll('[data-id="' + targetId + '"]').forEach(function(t) {
        t.classList.add('active');
      });
    }
  }, true);

  function initDefault() {
    document.querySelectorAll('.product-more-info').forEach(function(section) {
      var anyShown = section.querySelector('.tab-pane.show');
      if (!anyShown) {
        var firstPane = section.querySelector('.tab-pane');
        if (firstPane) firstPane.classList.add('show');
        var firstNav = section.querySelector('.more-info-tabs__nav-link');
        if (firstNav) firstNav.classList.add('active');
      }
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initDefault);
  } else {
    initDefault();
  }
})();
</script>

{% schema %}
  {
    "name": "Product Tab",
	"disabled_on": {
		"groups": ["header"]
	},
    "settings": [
		{
			"type": "text",
			"id": "margin",
			"label": "Margin",
			"default": "30px 0"
		},
		{
			"type": "select",
			"id": "tab_layout",
			"label": "Tab layout",
			"default": "tab",
			"options": [
				{
					"value": "tab",
					"label": "Tab"
				},
				{
					"value": "vertical",
					"label": "Vertical"
				},
				{
					"value": "full-content",
					"label": "Full Content"
				}
			]
		}
    ],
	"blocks": [
		{
            "type": "@app"
        },
		{
			"type": "tab_review",
			"name": "Tab review",
            "limit": 1,
            "settings": [
				{
					"type": "text",
					"id": "title_review",
					"label": "Title review",
					"default": "Review"
				}
            ]
		},
		{
			"type": "tab_custom",
			"name": "Tab custom",
            "settings": [
				{
					"type": "text",
					"id": "title_custom",
					"label": "Title custom",
					"default": "Custom"
				},
				{
					"type": "richtext",
					"id": "content_custom",
					"label": "Content custom"
				}
            ]
		}
	],
	"presets": [
		{
			"name": "Product Tab",
			"blocks": [
                {
                    "type": "tab_custom"
                },
                {
                    "type": "tab_review"
                }
			]
		}
    ]
  }
{% endschema %}
