{%- comment -%} BM Desktop Header v6 — predictive search panel with live suggestions {%- endcomment -%}
{%- comment -%}
  Black Mango desktop header with full controls.
  Hidden on mobile (mobile uses bm-mobile-nav). Self-contained CSS+JS,
  no dependencies on theme JS.
{%- endcomment -%}

{%- assign menu = linklists[section.settings.menu] -%}
{%- if menu == blank -%}{%- assign menu = linklists.main-menu -%}{%- endif -%}

{%- if section.settings.menu_font -%}
  {%- style -%}
    {{ section.settings.menu_font | font_face: font_display: 'swap' }}
  {%- endstyle -%}
  {%- assign menu_font_family = section.settings.menu_font.family -%}
{%- else -%}
  {%- assign menu_font_family = 'Manrope' -%}
{%- endif -%}

<header id="bm-dh-{{ section.id }}" class="bm-dh{% if section.settings.sticky %} bm-dh--sticky{% endif %}"
        style="--dh-bg: {{ section.settings.bg_color | default: '#ffffff' }};
               --dh-color: {{ section.settings.text_color | default: '#000000' }};
               --dh-hover: {{ section.settings.hover_color | default: '#000000' }};
               --dh-accent: {{ section.settings.accent_color | default: '#000000' }};
               --dh-border: {{ section.settings.border_color | default: '#eeeeee' }};
               --dh-pad-y: {{ section.settings.padding_y | default: 18 }}px;
               --dh-font-size: {{ section.settings.font_size | default: 13 }}px;
               --dh-letter-spacing: {{ section.settings.letter_spacing | default: 1 }}px;
               --dh-font-weight: {{ section.settings.font_weight | default: '500' }};
               --dh-menu-font: '{{ menu_font_family }}', var(--font-family-base, 'Manrope'), sans-serif;
               --dh-dropdown-bg: {{ section.settings.dropdown_bg | default: '#ffffff' }};
               --dh-dropdown-color: {{ section.settings.dropdown_color | default: '#000000' }};
               --dh-dropdown-hover: {{ section.settings.dropdown_hover_color | default: '#666666' }};">

  {%- assign layout = section.settings.layout | default: 'menu-below' -%}

  <div class="bm-dh__inner bm-dh--{{ layout }}">

    {%- comment -%}
      Left slot:
      - menu-below       → empty
      - menu-inline      → logo
      - menu-left-logo-center → menu
    {%- endcomment -%}
    <div class="bm-dh__left">
      {%- if layout == 'menu-inline' -%}
        <a href="/" class="bm-dh__logo">
          {%- if section.settings.logo -%}
            <img src="{{ section.settings.logo | image_url: width: 480 }}"
                 alt="{{ shop.name | escape }}"
                 style="height: {{ section.settings.logo_height | default: 44 }}px;">
          {%- else -%}
            <span class="bm-dh__logo-text">{{ shop.name }}</span>
          {%- endif -%}
        </a>
      {%- elsif layout == 'menu-left-logo-center' -%}
        <nav class="bm-dh__nav bm-dh__nav--left" aria-label="Main navigation">
          {%- render 'bm-dh-menu', menu: menu -%}
        </nav>
      {%- endif -%}
    </div>

    {%- comment -%}
      Center slot:
      - menu-below       → logo
      - menu-inline      → menu
      - menu-left-logo-center → logo
    {%- endcomment -%}
    <div class="bm-dh__center">
      {%- if layout == 'menu-inline' -%}
        <nav class="bm-dh__nav" aria-label="Main navigation">
          {%- render 'bm-dh-menu', menu: menu -%}
        </nav>
      {%- else -%}
        <a href="/" class="bm-dh__logo">
          {%- if section.settings.logo -%}
            <img src="{{ section.settings.logo | image_url: width: 600 }}"
                 alt="{{ shop.name | escape }}"
                 style="height: {{ section.settings.logo_height | default: 56 }}px;">
          {%- else -%}
            <span class="bm-dh__logo-text">{{ shop.name }}</span>
          {%- endif -%}
        </a>
      {%- endif -%}
    </div>

    {%- comment -%} Right slot: icons {%- endcomment -%}
    <div class="bm-dh__right">
      {%- if section.settings.show_search -%}
        <button type="button" class="bm-dh__icon bm-dh__search-toggle" data-bm-dh-search-toggle aria-label="Search" aria-expanded="false">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
        </button>
      {%- endif -%}
      {%- if section.settings.show_account -%}
        <a href="{{ routes.account_url }}" class="bm-dh__icon" aria-label="Account">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
        </a>
      {%- endif -%}
      {%- if section.settings.show_wishlist -%}
        <a href="{{ section.settings.wishlist_url | default: '/pages/wishlist' }}" class="bm-dh__icon" aria-label="Wishlist">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
          <span class="bm-dh__badge" data-count-wishlist>0</span>
        </a>
      {%- endif -%}
      {%- if section.settings.show_cart -%}
        <a href="/cart" class="bm-dh__icon" aria-label="Cart">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path><line x1="3" y1="6" x2="21" y2="6"></line><path d="M16 10a4 4 0 0 1-8 0"></path></svg>
          <span class="bm-dh__badge" data-cart-count>{{ cart.item_count }}</span>
        </a>
      {%- endif -%}
    </div>
  </div>

  {%- comment -%} Menu below logo when layout is menu-below {%- endcomment -%}
  {%- if layout == 'menu-below' -%}
    <nav class="bm-dh__row-nav" aria-label="Main navigation">
      {%- render 'bm-dh-menu', menu: menu -%}
    </nav>
  {%- endif -%}

  {%- if section.settings.show_search -%}
    <div class="bm-dh__search-panel" data-bm-dh-search-panel aria-hidden="true">
      <div class="bm-dh__search-inner">
        <form action="{{ routes.search_url }}" method="get" class="bm-dh__search-form" role="search">
          <input type="hidden" name="type" value="product">
          <input type="hidden" name="options[prefix]" value="last">
          <svg class="bm-dh__search-icon" viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
          <input class="bm-dh__search-input"
                 type="search"
                 name="q"
                 placeholder="{{ section.settings.search_placeholder | default: 'Search for cushions, rugs, throws…' }}"
                 autocomplete="off"
                 spellcheck="false"
                 aria-label="Search products"
                 data-bm-dh-search-input>
          <button type="button" class="bm-dh__search-close" data-bm-dh-search-close aria-label="Close search">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
          </button>
        </form>
        <div class="bm-dh__search-results" data-bm-dh-search-results aria-live="polite"></div>
      </div>
    </div>
    <div class="bm-dh__search-backdrop" data-bm-dh-search-close></div>
  {%- endif -%}
</header>

<style>
  #bm-dh-{{ section.id }}.bm-dh {
    display: none;
    background: var(--dh-bg);
    color: var(--dh-color);
    border-bottom: 1px solid var(--dh-border);
    font-family: var(--dh-menu-font);
    font-size: var(--dh-font-size);
    letter-spacing: var(--dh-letter-spacing);
    font-weight: var(--dh-font-weight);
  }
  @media (min-width: 992px) {
    #bm-dh-{{ section.id }}.bm-dh { display: block; }
  }
  #bm-dh-{{ section.id }}.bm-dh--sticky {
    position: -webkit-sticky !important;
    position: sticky !important;
    top: 0 !important;
    z-index: 8990 !important;
    will-change: box-shadow;
    transition: box-shadow .25s ease;
  }
  /* Subtle drop-shadow once the user has scrolled, gives a premium "lifting" feel */
  #bm-dh-{{ section.id }}.bm-dh--sticky.is-scrolled {
    box-shadow: 0 4px 18px rgba(0, 0, 0, .06);
  }
  #bm-dh-{{ section.id }} .bm-dh__inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: var(--dh-pad-y) 32px;
    display: grid;
    align-items: center;
    gap: 16px;
  }
  #bm-dh-{{ section.id }} .bm-dh__inner.bm-dh--menu-inline {
    grid-template-columns: auto 1fr auto;
  }
  #bm-dh-{{ section.id }} .bm-dh__inner.bm-dh--menu-below,
  #bm-dh-{{ section.id }} .bm-dh__inner.bm-dh--menu-left-logo-center {
    grid-template-columns: 1fr auto 1fr;
  }
  #bm-dh-{{ section.id }} .bm-dh__inner.bm-dh--menu-left-logo-center .bm-dh__left { justify-content: flex-start; }
  #bm-dh-{{ section.id }} .bm-dh__nav--left { justify-content: flex-start; }
  #bm-dh-{{ section.id }} .bm-dh__left { display: flex; align-items: center; }
  #bm-dh-{{ section.id }} .bm-dh__center { display: flex; align-items: center; justify-content: center; }
  #bm-dh-{{ section.id }} .bm-dh__right { display: flex; align-items: center; justify-content: flex-end; gap: 18px; }
  #bm-dh-{{ section.id }} .bm-dh__logo {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    color: var(--dh-color);
  }
  #bm-dh-{{ section.id }} .bm-dh__logo img { display: block; }
  #bm-dh-{{ section.id }} .bm-dh__logo-text {
    font-family: var(--font-family-second), 'Cormorant Garamond', serif;
    font-size: 30px;
    color: var(--dh-color);
    letter-spacing: 0;
  }
  #bm-dh-{{ section.id }} .bm-dh__icon {
    color: var(--dh-color);
    text-decoration: none;
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: color .2s ease;
    padding: 4px;
  }
  #bm-dh-{{ section.id }} .bm-dh__icon:hover { color: var(--dh-hover); }
  #bm-dh-{{ section.id }} .bm-dh__badge {
    position: absolute;
    top: -2px;
    right: -6px;
    background: var(--dh-accent);
    color: #ffffff;
    font-size: 10px;
    line-height: 1;
    border-radius: 999px;
    padding: 3px 5px;
    min-width: 16px;
    text-align: center;
    letter-spacing: 0;
    font-weight: 600;
  }

  /* Menu */
  #bm-dh-{{ section.id }} .bm-dh__nav,
  #bm-dh-{{ section.id }} .bm-dh__row-nav {
    display: flex;
    align-items: center;
    gap: {{ section.settings.menu_gap | default: 32 }}px;
  }
  #bm-dh-{{ section.id }} .bm-dh__row-nav {
    justify-content: center;
    border-top: 1px solid var(--dh-border);
    padding: 12px 32px;
    margin: 0 auto;
    max-width: 1440px;
  }
  #bm-dh-{{ section.id }} .bm-dh__menu-item {
    position: relative;
  }
  #bm-dh-{{ section.id }} .bm-dh__menu-link {
    color: var(--dh-color);
    text-decoration: none;
    text-transform: {{ section.settings.menu_case | default: 'uppercase' }};
    padding: 8px 0;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    transition: color .2s ease;
  }
  #bm-dh-{{ section.id }} .bm-dh__menu-link:hover,
  #bm-dh-{{ section.id }} .bm-dh__menu-item.is-active > .bm-dh__menu-link { color: var(--dh-hover); }
  #bm-dh-{{ section.id }} .bm-dh__menu-caret {
    width: 10px;
    height: 10px;
    display: inline-block;
    transition: transform .2s ease;
  }
  #bm-dh-{{ section.id }} .bm-dh__menu-item:hover > .bm-dh__menu-link .bm-dh__menu-caret { transform: rotate(180deg); }

  /* Premium dropdown */
  #bm-dh-{{ section.id }} .bm-dh__dropdown {
    position: absolute;
    top: calc(100% + 14px);
    left: 0;
    background-color: var(--dh-dropdown-bg, #ffffff);
    background-image: none;
    color: var(--dh-dropdown-color);
    min-width: 240px;
    padding: 16px 0;
    opacity: 0;
    visibility: hidden;
    transform: translateY(12px) scale(.98);
    transform-origin: top center;
    transition: opacity .28s cubic-bezier(.2,.7,.2,1),
                transform .28s cubic-bezier(.2,.7,.2,1),
                visibility .28s ease;
    z-index: 8995;
    box-shadow: 0 24px 60px rgba(0,0,0,.10), 0 2px 6px rgba(0,0,0,.04);
    border-radius: 2px;
    border-top: 2px solid var(--dh-accent);
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
  }
  /* Bridge so the gap between trigger and dropdown is still hoverable */
  #bm-dh-{{ section.id }} .bm-dh__dropdown::before {
    content: '';
    position: absolute;
    top: -16px;
    left: 0;
    right: 0;
    height: 16px;
  }
  /* Pointer triangle */
  #bm-dh-{{ section.id }} .bm-dh__dropdown::after {
    content: '';
    position: absolute;
    top: -7px;
    left: 28px;
    width: 12px;
    height: 12px;
    background-color: var(--dh-dropdown-bg, #ffffff);
    border-top: 2px solid var(--dh-accent);
    border-left: 2px solid var(--dh-accent);
    transform: rotate(45deg);
  }
  #bm-dh-{{ section.id }} .bm-dh__menu-item:hover > .bm-dh__dropdown,
  #bm-dh-{{ section.id }} .bm-dh__menu-item:focus-within > .bm-dh__dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateY(0) scale(1);
  }
  #bm-dh-{{ section.id }} .bm-dh__dropdown a {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: {{ section.settings.dropdown_item_padding | default: 11 }}px 26px;
    color: var(--dh-dropdown-color);
    text-decoration: none;
    text-transform: {{ section.settings.dropdown_case | default: 'none' }};
    letter-spacing: {{ section.settings.dropdown_letter_spacing | default: 0.4 }}px;
    font-family: var(--dh-menu-font, var(--font-family-base, 'Manrope', sans-serif));
    font-size: {{ section.settings.dropdown_font_size | default: 14 }}px;
    font-weight: {{ section.settings.dropdown_font_weight | default: '400' }};
    line-height: 1.4;
    transition: color .25s ease, padding-left .25s ease, background .25s ease;
    position: relative;
  }
  #bm-dh-{{ section.id }} .bm-dh__dropdown a::before {
    content: '';
    width: 0;
    height: 1px;
    background: currentColor;
    transition: width .25s ease;
    display: inline-block;
  }
  #bm-dh-{{ section.id }} .bm-dh__dropdown a:hover {
    color: var(--dh-dropdown-hover);
    padding-left: 32px;
  }
  #bm-dh-{{ section.id }} .bm-dh__dropdown a:hover::before {
    width: 14px;
    margin-right: 4px;
  }
  #bm-dh-{{ section.id }} .bm-dh__row-nav .bm-dh__dropdown { left: 50%; transform: translate(-50%, 12px) scale(.98); }
  #bm-dh-{{ section.id }} .bm-dh__row-nav .bm-dh__dropdown::after { left: 50%; margin-left: -6px; }
  #bm-dh-{{ section.id }} .bm-dh__row-nav .bm-dh__menu-item:hover > .bm-dh__dropdown,
  #bm-dh-{{ section.id }} .bm-dh__row-nav .bm-dh__menu-item:focus-within > .bm-dh__dropdown {
    transform: translate(-50%, 0) scale(1);
  }

  /* Hide stock theme desktop header on desktop to avoid duplicates */
  @media (min-width: 992px) {
    .bwp-header,
    .header-group { display: none !important; }
  }

  /* Search panel */
  #bm-dh-{{ section.id }} .bm-dh__search-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,.35);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity .22s ease, visibility .22s ease;
    z-index: 8970;
  }
  #bm-dh-{{ section.id }}.is-search-open .bm-dh__search-backdrop {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }
  #bm-dh-{{ section.id }} .bm-dh__search-panel {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: #ffffff;
    border-top: 1px solid var(--dh-border);
    border-bottom: 1px solid var(--dh-border);
    box-shadow: 0 18px 40px rgba(0,0,0,.08);
    transform: translateY(-12px);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: transform .28s cubic-bezier(.2,.7,.2,1),
                opacity .22s ease,
                visibility .22s ease;
    z-index: 8980;
  }
  #bm-dh-{{ section.id }}.is-search-open .bm-dh__search-panel {
    transform: translateY(0);
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }
  #bm-dh-{{ section.id }} .bm-dh__search-inner {
    max-width: 880px;
    margin: 0 auto;
    padding: 22px 24px 28px;
  }
  #bm-dh-{{ section.id }} .bm-dh__search-form {
    display: flex;
    align-items: center;
    gap: 12px;
    border-bottom: 1px solid #e5e5e5;
    padding-bottom: 12px;
  }
  #bm-dh-{{ section.id }} .bm-dh__search-icon { flex: 0 0 auto; color: var(--dh-color); }
  #bm-dh-{{ section.id }} .bm-dh__search-input {
    flex: 1;
    border: 0;
    background: transparent;
    outline: none;
    font-family: var(--dh-menu-font, var(--font-family-base, 'Manrope', sans-serif));
    font-size: 18px;
    color: var(--dh-color);
    padding: 8px 0;
    letter-spacing: 0.3px;
  }
  #bm-dh-{{ section.id }} .bm-dh__search-input::placeholder { color: #999; }
  #bm-dh-{{ section.id }} .bm-dh__search-close {
    flex: 0 0 auto;
    background: transparent;
    border: 0;
    padding: 6px;
    cursor: pointer;
    color: var(--dh-color);
    display: inline-flex;
  }
  #bm-dh-{{ section.id }} .bm-dh__search-close:hover { opacity: .7; }

  #bm-dh-{{ section.id }} .bm-dh__search-results {
    margin-top: 14px;
    max-height: 60vh;
    overflow-y: auto;
  }
  #bm-dh-{{ section.id }} .bm-dh__sr-state {
    padding: 24px 0;
    text-align: center;
    color: #888;
    font-size: 13px;
    letter-spacing: 0.4px;
  }
  #bm-dh-{{ section.id }} .bm-dh__sr-group + .bm-dh__sr-group { margin-top: 18px; }
  #bm-dh-{{ section.id }} .bm-dh__sr-heading {
    font-family: var(--dh-menu-font, var(--font-family-base, 'Manrope', sans-serif));
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 1.6px;
    color: #888;
    margin: 0 0 10px;
    padding-left: 4px;
  }
  #bm-dh-{{ section.id }} .bm-dh__sr-item {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 10px 8px;
    border-radius: 2px;
    text-decoration: none;
    color: var(--dh-color);
    transition: background .18s ease;
  }
  #bm-dh-{{ section.id }} .bm-dh__sr-item:hover,
  #bm-dh-{{ section.id }} .bm-dh__sr-item.is-active { background: #f6f6f6; }
  #bm-dh-{{ section.id }} .bm-dh__sr-thumb {
    flex: 0 0 56px;
    width: 56px;
    height: 56px;
    background: #f3f3f3;
    overflow: hidden;
    border-radius: 2px;
  }
  #bm-dh-{{ section.id }} .bm-dh__sr-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
  #bm-dh-{{ section.id }} .bm-dh__sr-meta { flex: 1 1 auto; min-width: 0; }
  #bm-dh-{{ section.id }} .bm-dh__sr-title {
    font-size: 14px;
    color: var(--dh-color);
    line-height: 1.35;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  #bm-dh-{{ section.id }} .bm-dh__sr-price {
    font-size: 12px;
    color: #666;
    margin-top: 3px;
    letter-spacing: 0.3px;
  }
  #bm-dh-{{ section.id }} .bm-dh__sr-price del { color: #999; margin-right: 6px; }
  #bm-dh-{{ section.id }} .bm-dh__sr-viewall {
    display: block;
    text-align: center;
    margin-top: 14px;
    padding: 12px;
    background: var(--dh-accent, #000);
    color: #fff;
    text-decoration: none;
    font-size: 12px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    transition: opacity .2s ease;
  }
  #bm-dh-{{ section.id }} .bm-dh__sr-viewall:hover { opacity: .85; }
</style>

<script>
(function() {
  var el = document.getElementById('bm-dh-{{ section.id }}');
  if (!el) return;

  /* ---------- Sticky scroll shadow ---------- */
  function updateScroll() {
    if (window.scrollY > 8) el.classList.add('is-scrolled');
    else el.classList.remove('is-scrolled');
  }
  window.addEventListener('scroll', updateScroll, { passive: true });
  updateScroll();

  /* ---------- Predictive search ---------- */
  var toggle  = el.querySelector('[data-bm-dh-search-toggle]');
  var panel   = el.querySelector('[data-bm-dh-search-panel]');
  var input   = el.querySelector('[data-bm-dh-search-input]');
  var results = el.querySelector('[data-bm-dh-search-results]');
  var closeBtns = el.querySelectorAll('[data-bm-dh-search-close]');
  if (!toggle || !panel || !input || !results) return;

  function openSearch() {
    el.classList.add('is-search-open');
    toggle.setAttribute('aria-expanded', 'true');
    panel.setAttribute('aria-hidden', 'false');
    setTimeout(function() { input.focus(); }, 60);
  }
  function closeSearch() {
    el.classList.remove('is-search-open');
    toggle.setAttribute('aria-expanded', 'false');
    panel.setAttribute('aria-hidden', 'true');
  }
  toggle.addEventListener('click', function(e) {
    e.preventDefault();
    if (el.classList.contains('is-search-open')) closeSearch();
    else openSearch();
  });
  closeBtns.forEach(function(b) { b.addEventListener('click', closeSearch); });
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && el.classList.contains('is-search-open')) closeSearch();
  });

  /* Show empty state when first opened */
  function setEmptyState() {
    results.innerHTML = '<div class="bm-dh__sr-state">Start typing to see products</div>';
  }
  setEmptyState();

  function fmtMoney(cents) {
    if (cents == null) return '';
    var n = parseFloat(cents) / 100;
    var s = n.toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ',');
    return 'Rs. ' + s;
  }
  function escapeHtml(str) {
    return String(str || '').replace(/[&<>"']/g, function(c) {
      return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c];
    });
  }

  function renderResults(q, data) {
    var products = (data && data.resources && data.resources.results && data.resources.results.products) || [];
    if (!products.length) {
      results.innerHTML = '<div class="bm-dh__sr-state">No products match "' + escapeHtml(q) + '"</div>';
      return;
    }
    var html = '<div class="bm-dh__sr-group"><h3 class="bm-dh__sr-heading">Products</h3>';
    products.forEach(function(p) {
      var img = p.featured_image || p.image || '';
      var imgUrl = img ? (img.indexOf('//') === 0 ? 'https:' + img : img).replace(/(\.[a-z]+)(\?|$)/i, '_120x$1$2') : '';
      var price = '';
      if (p.price != null) {
        var cur = fmtMoney(p.price);
        var comp = p.compare_at_price != null ? fmtMoney(p.compare_at_price) : '';
        if (comp && parseFloat(p.compare_at_price) > parseFloat(p.price)) {
          price = '<del>' + comp + '</del>' + cur;
        } else {
          price = cur;
        }
      }
      html += '<a class="bm-dh__sr-item" href="' + escapeHtml(p.url) + '">' +
                '<span class="bm-dh__sr-thumb">' + (imgUrl ? '<img src="' + escapeHtml(imgUrl) + '" alt="" loading="lazy">' : '') + '</span>' +
                '<span class="bm-dh__sr-meta">' +
                  '<span class="bm-dh__sr-title">' + escapeHtml(p.title) + '</span>' +
                  (price ? '<span class="bm-dh__sr-price">' + price + '</span>' : '') +
                '</span>' +
              '</a>';
    });
    html += '</div>';
    html += '<a class="bm-dh__sr-viewall" href="/search?q=' + encodeURIComponent(q) + '&type=product">View all results for "' + escapeHtml(q) + '"</a>';
    results.innerHTML = html;
  }

  var debounceTimer = null;
  var lastReqId = 0;
  function search(q) {
    var reqId = ++lastReqId;
    var url = '/search/suggest.json?q=' + encodeURIComponent(q)
            + '&resources[type]=product'
            + '&resources[limit]=8'
            + '&resources[options][unavailable_products]=last'
            + '&resources[options][fields]=title,product_type,vendor,tag';
    fetch(url, { headers: { 'Accept': 'application/json' } })
      .then(function(r) { return r.ok ? r.json() : null; })
      .then(function(data) {
        if (reqId !== lastReqId) return; // stale response
        renderResults(q, data);
      })
      .catch(function() {
        if (reqId !== lastReqId) return;
        results.innerHTML = '<div class="bm-dh__sr-state">Couldn\'t fetch suggestions. Try pressing Enter.</div>';
      });
  }
  input.addEventListener('input', function() {
    var q = input.value.trim();
    clearTimeout(debounceTimer);
    if (q.length < 2) { setEmptyState(); return; }
    results.innerHTML = '<div class="bm-dh__sr-state">Searching…</div>';
    debounceTimer = setTimeout(function() { search(q); }, 200);
  });

  /* Arrow-key navigation in the results list */
  input.addEventListener('keydown', function(e) {
    if (e.key !== 'ArrowDown' && e.key !== 'ArrowUp') return;
    var items = results.querySelectorAll('.bm-dh__sr-item');
    if (!items.length) return;
    e.preventDefault();
    var idx = -1;
    items.forEach(function(it, i) { if (it.classList.contains('is-active')) idx = i; });
    items.forEach(function(it) { it.classList.remove('is-active'); });
    if (e.key === 'ArrowDown') idx = Math.min(idx + 1, items.length - 1);
    else idx = Math.max(idx - 1, 0);
    items[idx].classList.add('is-active');
    items[idx].scrollIntoView({ block: 'nearest' });
  });
  results.addEventListener('mouseover', function(e) {
    var it = e.target.closest('.bm-dh__sr-item');
    if (!it) return;
    results.querySelectorAll('.bm-dh__sr-item').forEach(function(x) { x.classList.remove('is-active'); });
    it.classList.add('is-active');
  });
})();
</script>

