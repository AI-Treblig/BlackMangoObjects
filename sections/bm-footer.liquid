{%- comment -%} BM sync v3 - 2026-05-11 {%- endcomment -%}
{%- comment -%}
  Black Mango footer with full backend controls.
  Mobile shows a stacked layout; desktop is column-based with newsletter row.
  v2 - resync
{%- endcomment -%}

<footer class="bm-footer"
        style="--ft-bg: {{ section.settings.bg_color | default: '#000000' }};
               --ft-color: {{ section.settings.text_color | default: '#878787' }};
               --ft-heading: {{ section.settings.heading_color | default: '#ffffff' }};
               --ft-hover: {{ section.settings.hover_color | default: '#ffffff' }};
               --ft-border: {{ section.settings.border_color | default: '#222222' }};
               --ft-heading-size: {{ section.settings.heading_size | default: 14 }}px;
               --ft-body-size: {{ section.settings.body_size | default: 14 }}px;
               --ft-pad-y: {{ section.settings.padding_y | default: 60 }}px;">

  <div class="bm-footer__main">
    <div class="bm-footer__container">

      {%- if section.settings.show_brand_row -%}
        <div class="bm-footer__brand">
          {%- if section.settings.logo != blank -%}
            <a href="/" class="bm-footer__logo">
              <img src="{{ section.settings.logo | image_url: width: 480 }}"
                   alt="{{ shop.name | escape }}"
                   style="height: {{ section.settings.logo_height | default: 48 }}px;">
            </a>
          {%- else -%}
            <a href="/" class="bm-footer__brand-text">{{ shop.name }}</a>
          {%- endif -%}
          {%- if section.settings.tagline != blank -%}
            <p class="bm-footer__tagline">{{ section.settings.tagline }}</p>
          {%- endif -%}
        </div>
      {%- endif -%}

      <div class="bm-footer__cols">
        {%- for block in section.blocks -%}
          {%- case block.type -%}

            {%- when 'links' -%}
              <div class="bm-footer__col" {{ block.shopify_attributes }}>
                {%- if block.settings.heading != blank -%}
                  <h3 class="bm-footer__heading">{{ block.settings.heading }}</h3>
                {%- endif -%}
                {%- assign blink = linklists[block.settings.menu] -%}
                {%- if blink.links.size > 0 -%}
                  <ul class="bm-footer__list">
                    {%- for l in blink.links -%}
                      <li><a href="{{ l.url }}">{{ l.title }}</a></li>
                    {%- endfor -%}
                  </ul>
                {%- endif -%}
              </div>

            {%- when 'text' -%}
              <div class="bm-footer__col" {{ block.shopify_attributes }}>
                {%- if block.settings.heading != blank -%}
                  <h3 class="bm-footer__heading">{{ block.settings.heading }}</h3>
                {%- endif -%}
                {%- if block.settings.content != blank -%}
                  <div class="bm-footer__rte">{{ block.settings.content }}</div>
                {%- endif -%}
              </div>

            {%- when 'contact' -%}
              <div class="bm-footer__col" {{ block.shopify_attributes }}>
                {%- if block.settings.heading != blank -%}
                  <h3 class="bm-footer__heading">{{ block.settings.heading }}</h3>
                {%- endif -%}
                <ul class="bm-footer__list bm-footer__list--contact">
                  {%- if block.settings.whatsapp != blank -%}
                    {%- assign wa = block.settings.whatsapp | replace: '+', '' | replace: ' ', '' | replace: '-', '' | replace: '(', '' | replace: ')', '' -%}
                    <li>
                      <a href="https://wa.me/{{ wa }}" target="_blank" rel="noopener">
                        <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor" aria-hidden="true"><path d="M17.6 6.32A7.85 7.85 0 0 0 12.05 4a7.94 7.94 0 0 0-6.88 11.89L4 20l4.22-1.11a7.93 7.93 0 0 0 3.83.98h.01a7.94 7.94 0 0 0 5.54-13.55zm-2 9.61c-.16.46-.94.88-1.34.95-.34.05-.78.07-1.26-.08-.29-.09-.66-.21-1.14-.42-2.01-.87-3.33-2.91-3.43-3.04-.1-.13-.82-1.08-.82-2.06s.52-1.47.7-1.67a.75.75 0 0 1 .54-.25l.39.01c.12 0 .29-.05.45.34.17.4.57 1.38.62 1.48.05.1.09.22.02.35-.07.13-.1.21-.2.33-.1.12-.21.26-.3.35-.1.09-.2.2-.09.4.11.2.51.85 1.12 1.38.76.68 1.4.89 1.6.99.2.1.32.08.43-.05.13-.13.5-.58.62-.78.13-.2.26-.17.45-.1.18.07 1.16.55 1.36.65.2.1.33.15.38.23.05.09.05.49-.11.95z"/></svg>
                        <span>WhatsApp: {{ block.settings.whatsapp }}</span>
                      </a>
                    </li>
                  {%- endif -%}
                  {%- if block.settings.phone != blank -%}
                    {%- assign ph = block.settings.phone | replace: ' ', '' | replace: '-', '' -%}
                    <li>
                      <a href="tel:{{ ph }}">
                        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
                        <span>Phone: {{ block.settings.phone }}</span>
                      </a>
                    </li>
                  {%- endif -%}
                  {%- if block.settings.email != blank -%}
                    <li>
                      <a href="mailto:{{ block.settings.email }}">
                        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
                        <span>Email: {{ block.settings.email }}</span>
                      </a>
                    </li>
                  {%- endif -%}
                  {%- if block.settings.hours != blank -%}
                    <li>
                      <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                      <span>{{ block.settings.hours }}</span>
                    </li>
                  {%- endif -%}
                </ul>
              </div>

            {%- when 'newsletter' -%}
              <div class="bm-footer__col bm-footer__col--news" {{ block.shopify_attributes }}>
                {%- if block.settings.heading != blank -%}
                  <h3 class="bm-footer__heading">{{ block.settings.heading }}</h3>
                {%- endif -%}
                {%- if block.settings.subheading != blank -%}
                  <p class="bm-footer__news-sub">{{ block.settings.subheading }}</p>
                {%- endif -%}
                {%- form 'customer', class: 'bm-footer__news-form' -%}
                  <input type="hidden" name="contact[tags]" value="newsletter">
                  <input type="email" name="contact[email]"
                         placeholder="{{ block.settings.placeholder | default: 'Email address' }}"
                         required aria-label="Email address">
                  <button type="submit" aria-label="Subscribe">
                    {%- if block.settings.button_label != blank -%}
                      {{ block.settings.button_label }}
                    {%- else -%}
                      <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
                    {%- endif -%}
                  </button>
                  {%- if form.posted_successfully? -%}
                    <p class="bm-footer__news-msg">Thanks for subscribing!</p>
                  {%- endif -%}
                {%- endform -%}

                {%- if section.settings.instagram != blank or section.settings.facebook != blank or section.settings.whatsapp_social != blank or section.settings.pinterest != blank or section.settings.youtube != blank -%}
                  <div class="bm-footer__social">
                    {%- if section.settings.instagram != blank -%}
                      <a href="{{ section.settings.instagram }}" target="_blank" rel="noopener" aria-label="Instagram">
                        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
                      </a>
                    {%- endif -%}
                    {%- if section.settings.facebook != blank -%}
                      <a href="{{ section.settings.facebook }}" target="_blank" rel="noopener" aria-label="Facebook">
                        <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M22 12a10 10 0 1 0-11.56 9.88v-6.99H7.9V12h2.54V9.8c0-2.5 1.49-3.89 3.77-3.89 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56V12h2.77l-.44 2.89h-2.33v6.99A10 10 0 0 0 22 12z"/></svg>
                      </a>
                    {%- endif -%}
                    {%- if section.settings.whatsapp_social != blank -%}
                      {%- assign was = section.settings.whatsapp_social | replace: '+', '' | replace: ' ', '' | replace: '-', '' -%}
                      <a href="https://wa.me/{{ was }}" target="_blank" rel="noopener" aria-label="WhatsApp">
                        <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M17.6 6.32A7.85 7.85 0 0 0 12.05 4a7.94 7.94 0 0 0-6.88 11.89L4 20l4.22-1.11a7.93 7.93 0 0 0 3.83.98h.01a7.94 7.94 0 0 0 5.54-13.55z"/></svg>
                      </a>
                    {%- endif -%}
                    {%- if section.settings.pinterest != blank -%}
                      <a href="{{ section.settings.pinterest }}" target="_blank" rel="noopener" aria-label="Pinterest">
                        <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M12 2a10 10 0 0 0-3.64 19.32c-.09-.77-.16-1.94.03-2.78.18-.76 1.14-4.86 1.14-4.86s-.29-.59-.29-1.45c0-1.36.79-2.38 1.78-2.38.84 0 1.24.63 1.24 1.39 0 .85-.54 2.12-.82 3.3-.23.98.49 1.78 1.46 1.78 1.76 0 3.11-1.85 3.11-4.52 0-2.36-1.7-4.02-4.12-4.02-2.81 0-4.46 2.11-4.46 4.28 0 .85.33 1.76.74 2.25.08.1.09.18.07.28-.08.32-.25 1.01-.28 1.15-.04.18-.15.22-.34.13-1.24-.58-2.02-2.4-2.02-3.86 0-3.14 2.28-6.03 6.58-6.03 3.46 0 6.14 2.47 6.14 5.76 0 3.44-2.17 6.21-5.18 6.21-1.01 0-1.96-.52-2.29-1.14l-.62 2.37c-.22.87-.84 1.96-1.25 2.62A10 10 0 1 0 12 2z"/></svg>
                      </a>
                    {%- endif -%}
                    {%- if section.settings.youtube != blank -%}
                      <a href="{{ section.settings.youtube }}" target="_blank" rel="noopener" aria-label="YouTube">
                        <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M21.58 7.19c-.23-.86-.92-1.55-1.79-1.78C18.22 5 12 5 12 5s-6.22 0-7.79.41c-.87.23-1.56.92-1.79 1.78C2 8.76 2 12 2 12s0 3.24.42 4.81c.23.86.92 1.55 1.79 1.78C5.78 19 12 19 12 19s6.22 0 7.79-.41c.87-.23 1.56-.92 1.79-1.78C22 15.24 22 12 22 12s0-3.24-.42-4.81zM10 15V9l5.2 3-5.2 3z"/></svg>
                      </a>
                    {%- endif -%}
                  </div>
                {%- endif -%}
              </div>

          {%- endcase -%}
        {%- endfor -%}
      </div>
    </div>
  </div>

  {%- if section.settings.show_bottom_strip -%}
    <div class="bm-footer__bottom">
      <div class="bm-footer__container bm-footer__bottom-inner">
        <div class="bm-footer__copy">
          {%- assign current_year = 'now' | date: '%Y' -%}
          {%- assign copy_text = section.settings.copyright | default: '© Black Mango. All rights reserved.' -%}
          {{ copy_text | replace: 'YEAR', current_year }}
        </div>
        {%- if section.settings.show_payment_icons -%}
          <div class="bm-footer__payments">
            {%- for type in shop.enabled_payment_types -%}
              {{ type | payment_type_svg_tag: class: 'bm-footer__payment' }}
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}
</footer>

<style>
  .bm-footer {
    background: var(--ft-bg);
    color: var(--ft-color);
    font-family: var(--font-family-base), 'Manrope', sans-serif;
    font-size: var(--ft-body-size);
  }
  .bm-footer__container {
    max-width: 1320px;
    margin: 0 auto;
    padding: 0 24px;
  }
  .bm-footer__main { padding: var(--ft-pad-y) 0; }

  .bm-footer__brand {
    text-align: center;
    margin-bottom: 40px;
    padding-bottom: 32px;
    border-bottom: 1px solid var(--ft-border);
  }
  .bm-footer__logo img { display: inline-block; }
  .bm-footer__brand-text {
    font-family: var(--font-family-second), 'Cormorant Garamond', serif;
    font-size: 36px;
    color: var(--ft-heading);
    text-decoration: none;
  }
  .bm-footer__tagline {
    margin: 14px auto 0;
    max-width: 580px;
    color: var(--ft-color);
    font-size: var(--ft-body-size);
    line-height: 1.6;
  }

  .bm-footer__cols {
    display: grid;
    grid-template-columns: repeat({{ section.settings.column_count | default: 4 }}, 1fr);
    gap: 40px;
  }
  .bm-footer__col--news { grid-column: span 1; }

  .bm-footer__heading {
    font-family: var(--font-family-base), 'Manrope', sans-serif;
    font-size: var(--ft-heading-size);
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--ft-heading);
    margin: 0 0 18px;
  }

  .bm-footer__list { list-style: none; margin: 0; padding: 0; }
  .bm-footer__list li { margin-bottom: 10px; }
  .bm-footer__list a {
    color: var(--ft-color);
    text-decoration: none;
    transition: color .2s ease;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .bm-footer__list a:hover { color: var(--ft-hover); }
  .bm-footer__list--contact li {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 10px;
  }

  .bm-footer__rte { line-height: 1.7; }
  .bm-footer__rte a { color: var(--ft-color); text-decoration: underline; }
  .bm-footer__rte a:hover { color: var(--ft-hover); }

  .bm-footer__news-sub {
    margin: 0 0 16px;
    color: var(--ft-color);
    line-height: 1.6;
  }
  .bm-footer__news-form {
    display: flex;
    border: 1px solid var(--ft-border);
    border-radius: 0;
    overflow: hidden;
  }
  .bm-footer__news-form input[type=email] {
    flex: 1;
    background: transparent;
    border: 0;
    padding: 12px 14px;
    color: var(--ft-heading);
    font-family: inherit;
    font-size: 13px;
    outline: none;
  }
  .bm-footer__news-form input[type=email]::placeholder { color: var(--ft-color); opacity: .8; }
  .bm-footer__news-form button {
    background: var(--ft-heading);
    color: var(--ft-bg);
    border: 0;
    padding: 0 18px;
    cursor: pointer;
    font-family: inherit;
    font-size: 12px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: opacity .2s ease;
  }
  .bm-footer__news-form button:hover { opacity: .85; }
  .bm-footer__news-msg { margin-top: 10px; color: var(--ft-hover); font-size: 13px; }

  .bm-footer__social {
    display: flex;
    gap: 12px;
    margin-top: 18px;
  }
  .bm-footer__social a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1px solid var(--ft-border);
    color: var(--ft-color);
    transition: background .2s ease, color .2s ease, border-color .2s ease;
  }
  .bm-footer__social a:hover {
    background: var(--ft-heading);
    color: var(--ft-bg);
    border-color: var(--ft-heading);
  }

  .bm-footer__bottom {
    border-top: 1px solid var(--ft-border);
    padding: 18px 0;
  }
  .bm-footer__bottom-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 14px;
  }
  .bm-footer__copy {
    color: var(--ft-color);
    font-size: 12px;
    letter-spacing: .5px;
  }
  .bm-footer__payments {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }
  .bm-footer__payment { height: 22px; }

  @media (max-width: 991px) {
    .bm-footer__cols { grid-template-columns: repeat(2, 1fr); gap: 28px 20px; }
  }
  @media (max-width: 600px) {
    .bm-footer__main { padding: 40px 0; }
    .bm-footer__cols { grid-template-columns: 1fr; gap: 24px; }
    .bm-footer__brand { margin-bottom: 28px; padding-bottom: 22px; }
    .bm-footer__brand-text { font-size: 28px; }
    .bm-footer__heading { font-size: 13px; margin-bottom: 12px; }
    .bm-footer__bottom-inner { justify-content: center; text-align: center; }
  }
</style>

{% schema %}
{
  "name": "BM Footer",
  "disabled_on": { "groups": ["header"] },
  "settings": [
    { "type": "header", "content": "Layout" },
    { "type": "range", "id": "column_count", "label": "Column count (desktop)", "min": 2, "max": 5, "step": 1, "default": 4 },
    { "type": "range", "id": "padding_y", "label": "Vertical padding (px)", "min": 20, "max": 120, "step": 4, "default": 60 },

    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#000000" },
    { "type": "color", "id": "heading_color", "label": "Headings & logo color", "default": "#ffffff" },
    { "type": "color", "id": "text_color", "label": "Body text & links", "default": "#878787" },
    { "type": "color", "id": "hover_color", "label": "Link hover", "default": "#ffffff" },
    { "type": "color", "id": "border_color", "label": "Dividers / borders", "default": "#222222" },

    { "type": "header", "content": "Typography" },
    { "type": "range", "id": "heading_size", "label": "Heading font size (px)", "min": 10, "max": 22, "step": 1, "default": 14 },
    { "type": "range", "id": "body_size", "label": "Body font size (px)", "min": 11, "max": 18, "step": 1, "default": 14 },

    { "type": "header", "content": "Brand row" },
    { "type": "checkbox", "id": "show_brand_row", "label": "Show brand row (logo + tagline)", "default": false },
    { "type": "image_picker", "id": "logo", "label": "Footer logo" },
    { "type": "range", "id": "logo_height", "label": "Logo height (px)", "min": 24, "max": 100, "step": 2, "default": 48 },
    { "type": "textarea", "id": "tagline", "label": "Tagline" },

    { "type": "header", "content": "Social links" },
    { "type": "url", "id": "instagram", "label": "Instagram URL" },
    { "type": "text", "id": "whatsapp_social", "label": "WhatsApp number", "info": "International format, e.g. 919876543210" },
    { "type": "url", "id": "facebook", "label": "Facebook URL" },
    { "type": "url", "id": "pinterest", "label": "Pinterest URL" },
    { "type": "url", "id": "youtube", "label": "YouTube URL" },

    { "type": "header", "content": "Bottom strip" },
    { "type": "checkbox", "id": "show_bottom_strip", "label": "Show bottom strip", "default": true },
    { "type": "text", "id": "copyright", "label": "Copyright text", "default": "© YEAR Black Mango. All rights reserved.", "info": "Use 'YEAR' (uppercase, no quotes) anywhere in the text to insert the current year automatically." },
    { "type": "checkbox", "id": "show_payment_icons", "label": "Show payment method icons", "default": false }
  ],
  "blocks": [
    {
      "type": "links",
      "name": "Menu column",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Shop" },
        { "type": "link_list", "id": "menu", "label": "Menu", "default": "footer", "info": "Edit menus in Online Store → Navigation." }
      ]
    },
    {
      "type": "text",
      "name": "Text column",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "About" },
        { "type": "richtext", "id": "content", "label": "Content", "default": "<p>Tell your story here.</p>" }
      ]
    },
    {
      "type": "contact",
      "name": "Contact column",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Contact Us" },
        { "type": "text", "id": "whatsapp", "label": "WhatsApp number", "info": "e.g. 919876543210 — auto-links to wa.me" },
        { "type": "text", "id": "phone", "label": "Phone number" },
        { "type": "text", "id": "email", "label": "Email address" },
        { "type": "text", "id": "hours", "label": "Business hours / extra line" }
      ]
    },
    {
      "type": "newsletter",
      "name": "Newsletter column",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Join Us" },
        { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Enter your email below to be the first to know about new collections and product launches." },
        { "type": "text", "id": "placeholder", "label": "Input placeholder", "default": "Email address" },
        { "type": "text", "id": "button_label", "label": "Button label (leave blank for icon only)" }
      ]
    }
  ],
  "presets": [{
    "name": "BM Footer",
    "blocks": [
      { "type": "links",      "settings": { "heading": "Collections" } },
      { "type": "links",      "settings": { "heading": "Services"    } },
      { "type": "contact",    "settings": { "heading": "Contact Us"  } },
      { "type": "newsletter", "settings": { "heading": "Join Us"     } }
    ]
  }]
}
{% endschema %}
