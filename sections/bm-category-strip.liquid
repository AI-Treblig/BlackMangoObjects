{%- comment -%}
  Black Mango category strip with full theme-editor controls.
  Desktop: grid of N columns. Mobile: horizontal peek-scroll showing N.x items.
{%- endcomment -%}

{%- assign cols_desktop = section.settings.cols_desktop | default: 5 -%}
{%- assign cols_tablet = section.settings.cols_tablet | default: 3 -%}
{%- assign mobile_visible = section.settings.mobile_visible | default: 1.5 -%}
{%- assign gap = section.settings.gap | default: 20 -%}
{%- assign circle_size_d = section.settings.circle_size_desktop | default: 140 -%}
{%- assign circle_size_m = section.settings.circle_size_mobile | default: 110 -%}
{%- assign pad_y_d = section.settings.padding_y_desktop | default: 50 -%}
{%- assign pad_y_m = section.settings.padding_y_mobile | default: 32 -%}
{%- assign pad_x_d = section.settings.padding_x_desktop | default: 60 -%}
{%- assign pad_x_m = section.settings.padding_x_mobile | default: 16 -%}
{%- assign label_size_d = section.settings.label_size_desktop | default: 14 -%}
{%- assign label_size_m = section.settings.label_size_mobile | default: 12 -%}
{%- assign label_gap = section.settings.label_gap | default: 18 -%}

<section class="bm-cats"
         id="bm-cats-{{ section.id }}"
         style="background-color: {{ section.settings.bg_color | default: '#000000' }};
                color: {{ section.settings.label_color | default: '#ffffff' }};">
  {%- if section.settings.bg_image -%}
    <div class="bm-cats__bg" aria-hidden="true"
         style="background-image: url('{{ section.settings.bg_image | image_url: width: 2400 }}');
                background-position: {{ section.settings.bg_image_position | default: 'center center' }};
                background-size: {{ section.settings.bg_image_size | default: 'cover' }};
                opacity: {{ section.settings.bg_image_opacity | default: 100 | divided_by: 100.0 }};"></div>
  {%- endif -%}

  <div class="bm-cats__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="bm-cats__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.settings.subheading != blank -%}
      <p class="bm-cats__sub">{{ section.settings.subheading }}</p>
    {%- endif -%}

    <div class="bm-cats__strip">
      {%- for block in section.blocks -%}
        {%- assign link_url = block.settings.url | default: '#' -%}
        <a href="{{ link_url }}" class="bm-cats__item" {{ block.shopify_attributes }}>
          <span class="bm-cats__circle"
                style="background: {{ block.settings.circle_bg | default: section.settings.circle_bg | default: '#ffffff' }};
                       border-color: {{ block.settings.circle_border_color | default: section.settings.circle_border_color | default: '#ffffff' }};
                       border-width: {{ section.settings.circle_border_width | default: 0 }}px;">
            {%- if block.settings.image -%}
              <img src="{{ block.settings.image | image_url: width: 320 }}" alt="{{ block.settings.label | escape }}" loading="lazy">
            {%- endif -%}
          </span>
          <span class="bm-cats__label">{{ block.settings.label }}</span>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  #bm-cats-{{ section.id }}.bm-cats {
    position: relative;
    padding: {{ pad_y_d }}px {{ pad_x_d }}px;
    overflow: hidden;
  }
  #bm-cats-{{ section.id }} .bm-cats__bg {
    position: absolute;
    inset: 0;
    background-repeat: no-repeat;
    pointer-events: none;
    z-index: 0;
  }
  #bm-cats-{{ section.id }} .bm-cats__inner {
    position: relative;
    z-index: 1;
    max-width: 1320px;
    margin: 0 auto;
  }
  #bm-cats-{{ section.id }} .bm-cats__heading {
    font-family: var(--font-family-second), 'Cormorant Garamond', serif;
    font-size: {{ section.settings.heading_size_desktop | default: 28 }}px;
    font-weight: 400;
    margin: 0 0 8px;
    text-align: {{ section.settings.heading_align | default: 'center' }};
    color: {{ section.settings.heading_color | default: section.settings.label_color | default: '#ffffff' }};
  }
  #bm-cats-{{ section.id }} .bm-cats__sub {
    font-family: var(--font-family-base), 'Manrope', sans-serif;
    font-size: 13px;
    margin: 0 0 28px;
    text-align: {{ section.settings.heading_align | default: 'center' }};
    color: {{ section.settings.heading_color | default: section.settings.label_color | default: '#ffffff' }};
    opacity: .85;
  }

  /* Desktop / tablet: CSS grid */
  #bm-cats-{{ section.id }} .bm-cats__strip {
    display: grid;
    grid-template-columns: repeat({{ cols_desktop }}, 1fr);
    gap: {{ gap }}px;
    justify-items: center;
  }
  @media (max-width: 991px) {
    #bm-cats-{{ section.id }} .bm-cats__strip {
      grid-template-columns: repeat({{ cols_tablet }}, 1fr);
    }
  }

  /* Mobile: horizontal peek-scroll showing N.x items */
  @media (max-width: 767px) {
    #bm-cats-{{ section.id }}.bm-cats {
      padding: {{ pad_y_m }}px {{ pad_x_m }}px;
    }
    #bm-cats-{{ section.id }} .bm-cats__heading {
      font-size: {{ section.settings.heading_size_mobile | default: 22 }}px;
    }
    #bm-cats-{{ section.id }} .bm-cats__strip {
      display: flex;
      grid-template-columns: none;
      overflow-x: auto;
      overflow-y: hidden;
      gap: {{ gap }}px;
      padding-bottom: 6px;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }
    #bm-cats-{{ section.id }} .bm-cats__strip::-webkit-scrollbar { display: none; }
    #bm-cats-{{ section.id }} .bm-cats__item {
      flex: 0 0 calc((100% - {{ gap }}px * ({{ mobile_visible }} - 1)) / {{ mobile_visible }});
      scroll-snap-align: start;
    }
  }

  #bm-cats-{{ section.id }} .bm-cats__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-decoration: none;
    color: inherit;
    gap: {{ label_gap }}px;
    -webkit-tap-highlight-color: transparent;
    transition: transform .25s ease;
  }
  #bm-cats-{{ section.id }} .bm-cats__item:hover { transform: translateY(-3px); }

  #bm-cats-{{ section.id }} .bm-cats__circle {
    width: {{ circle_size_d }}px;
    height: {{ circle_size_d }}px;
    border-radius: 50%;
    border-style: solid;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    box-sizing: border-box;
  }
  @media (max-width: 767px) {
    #bm-cats-{{ section.id }} .bm-cats__circle {
      width: {{ circle_size_m }}px;
      height: {{ circle_size_m }}px;
    }
  }
  #bm-cats-{{ section.id }} .bm-cats__circle img {
    width: 60%;
    height: 60%;
    object-fit: contain;
    display: block;
  }
  #bm-cats-{{ section.id }} .bm-cats__label {
    font-family: var(--font-family-base), 'Manrope', sans-serif;
    font-size: {{ label_size_d }}px;
    color: {{ section.settings.label_color | default: '#ffffff' }};
    letter-spacing: {{ section.settings.label_letter_spacing | default: 0.5 }}px;
    text-transform: {{ section.settings.label_case | default: 'none' }};
    text-align: center;
    line-height: 1.3;
  }
  @media (max-width: 767px) {
    #bm-cats-{{ section.id }} .bm-cats__label {
      font-size: {{ label_size_m }}px;
    }
  }
</style>

{% schema %}
{
  "name": "BM Category Strip",
  "settings": [
    { "type": "header", "content": "Background" },
    { "type": "color", "id": "bg_color", "label": "Background color", "default": "#000000" },
    { "type": "image_picker", "id": "bg_image", "label": "Background image (optional)" },
    { "type": "range", "id": "bg_image_opacity", "label": "Background image opacity (%)", "min": 0, "max": 100, "step": 5, "default": 100 },
    { "type": "select", "id": "bg_image_position", "label": "Background image position",
      "options": [
        { "value": "center center", "label": "Center" },
        { "value": "center top", "label": "Top" },
        { "value": "center bottom", "label": "Bottom" },
        { "value": "left center", "label": "Left" },
        { "value": "right center", "label": "Right" }
      ],
      "default": "center center"
    },
    { "type": "select", "id": "bg_image_size", "label": "Background image size",
      "options": [
        { "value": "cover", "label": "Cover (fills)" },
        { "value": "contain", "label": "Contain (fits)" },
        { "value": "100% 100%", "label": "Stretch" },
        { "value": "auto", "label": "Original" }
      ],
      "default": "cover"
    },

    { "type": "header", "content": "Heading (optional)" },
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "text", "id": "subheading", "label": "Subheading" },
    { "type": "range", "id": "heading_size_desktop", "label": "Heading size — desktop (px)", "min": 16, "max": 56, "step": 2, "default": 28 },
    { "type": "range", "id": "heading_size_mobile", "label": "Heading size — mobile (px)", "min": 14, "max": 36, "step": 1, "default": 22 },
    { "type": "color", "id": "heading_color", "label": "Heading color", "default": "#ffffff" },
    { "type": "select", "id": "heading_align", "label": "Heading alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },

    { "type": "header", "content": "Layout & spacing" },
    { "type": "range", "id": "cols_desktop", "label": "Columns — desktop", "min": 2, "max": 8, "step": 1, "default": 5 },
    { "type": "range", "id": "cols_tablet", "label": "Columns — tablet", "min": 2, "max": 6, "step": 1, "default": 3 },
    { "type": "range", "id": "mobile_visible", "label": "Items visible — mobile", "min": 1, "max": 4, "step": 0.5, "default": 1.5, "info": "Use 1.5 to show 1 full + half of the next, hinting at horizontal scroll." },
    { "type": "range", "id": "gap", "label": "Gap between items (px)", "min": 0, "max": 60, "step": 2, "default": 20 },
    { "type": "range", "id": "padding_y_desktop", "label": "Vertical padding — desktop (px)", "min": 0, "max": 200, "step": 4, "default": 50 },
    { "type": "range", "id": "padding_y_mobile", "label": "Vertical padding — mobile (px)", "min": 0, "max": 120, "step": 4, "default": 32 },
    { "type": "range", "id": "padding_x_desktop", "label": "Horizontal padding — desktop (px)", "min": 0, "max": 160, "step": 4, "default": 60 },
    { "type": "range", "id": "padding_x_mobile", "label": "Horizontal padding — mobile (px)", "min": 0, "max": 60, "step": 2, "default": 16 },

    { "type": "header", "content": "Circle (icon container)" },
    { "type": "range", "id": "circle_size_desktop", "label": "Circle size — desktop (px)", "min": 60, "max": 240, "step": 4, "default": 140 },
    { "type": "range", "id": "circle_size_mobile", "label": "Circle size — mobile (px)", "min": 50, "max": 180, "step": 2, "default": 110 },
    { "type": "color", "id": "circle_bg", "label": "Circle background", "default": "#ffffff" },
    { "type": "color", "id": "circle_border_color", "label": "Circle border color", "default": "#ffffff" },
    { "type": "range", "id": "circle_border_width", "label": "Circle border width (px)", "min": 0, "max": 8, "step": 1, "default": 0 },

    { "type": "header", "content": "Label (caption)" },
    { "type": "range", "id": "label_size_desktop", "label": "Label size — desktop (px)", "min": 10, "max": 22, "step": 1, "default": 14 },
    { "type": "range", "id": "label_size_mobile", "label": "Label size — mobile (px)", "min": 9, "max": 18, "step": 1, "default": 12 },
    { "type": "color", "id": "label_color", "label": "Label color", "default": "#ffffff" },
    { "type": "select", "id": "label_case", "label": "Label case",
      "options": [
        { "value": "none", "label": "Original" },
        { "value": "uppercase", "label": "UPPERCASE" },
        { "value": "lowercase", "label": "lowercase" },
        { "value": "capitalize", "label": "Capitalize Each Word" }
      ],
      "default": "none"
    },
    { "type": "range", "id": "label_letter_spacing", "label": "Label letter spacing (px)", "min": 0, "max": 5, "step": 0.5, "default": 0.5 },
    { "type": "range", "id": "label_gap", "label": "Space between circle and label (px)", "min": 0, "max": 40, "step": 2, "default": 18 }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Icon image", "info": "Square works best. PNG with transparent background recommended." },
        { "type": "text", "id": "label", "label": "Label", "default": "Category" },
        { "type": "url", "id": "url", "label": "Link" },
        { "type": "color", "id": "circle_bg", "label": "Override circle background (optional)" },
        { "type": "color", "id": "circle_border_color", "label": "Override circle border color (optional)" }
      ]
    }
  ],
  "presets": [{
    "name": "BM Category Strip",
    "blocks": [
      { "type": "category", "settings": { "label": "Rugs" } },
      { "type": "category", "settings": { "label": "Cushion Covers" } },
      { "type": "category", "settings": { "label": "Curtains" } },
      { "type": "category", "settings": { "label": "Throws" } },
      { "type": "category", "settings": { "label": "Objects" } }
    ]
  }]
}
{% endschema %}
